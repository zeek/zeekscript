    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "z"
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"c\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
