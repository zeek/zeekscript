COMMENT-LEADING "# Sequence interrupted by non-if: 2 + 3."
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "i"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"a\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "y"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"b\""
          SEMI
        }
      }
    }
    PRINT {
      KEYWORD "print"
      SP
      CONSTANT "\"mid\""
      SEMI
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "a"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"c\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "b"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"d\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "c"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"e\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
