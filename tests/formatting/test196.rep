      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"a\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "y"
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"b\""
          SEMI
        }
