COMMENT-LEADING "# if with comment before body: should NOT inline."
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "j"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      COMMENT-LEADING "# comment before body"
      BODY {
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "\"done\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "y"
      RPAREN
      BODY {
        SAME-LINE
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "\"two\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "z"
      RPAREN
      BODY {
        SAME-LINE
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "\"three\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
