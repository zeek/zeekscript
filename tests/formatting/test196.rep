COMMENT-LEADING "# 3+ inline ifs: all fit, should inline."
FUNC-DECL-RET {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    PARAM "val" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "string"
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "in" {
        CONSTANT "/aaa/i"
        OP "in"
        IDENTIFIER "val"
      }
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"aaa\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "in" {
        CONSTANT "/bbb/i"
        OP "in"
        IDENTIFIER "val"
      }
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"bbb\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "in" {
        CONSTANT "/ccc/i"
        OP "in"
        IDENTIFIER "val"
      }
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"ccc\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "in" {
        CONSTANT "/ddd/i"
        OP "in"
        IDENTIFIER "val"
      }
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"ddd\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "in" {
        CONSTANT "/eee/"
        OP "in"
        IDENTIFIER "val"
      }
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"eee\""
          SEMI
        }
      }
    }
    BLANK
    RETURN {
      KEYWORD "return"
      SP
      IDENTIFIER "val"
      SEMI
    }
    RBRACE
  }
}
BLANK
COMMENT-LEADING "# Only 2 ifs: should NOT inline."
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "g"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"a\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "y"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"b\""
          SEMI
        }
      }
    }
    RETURN {
      KEYWORD "return"
      SP
      CONSTANT "\"c\""
      SEMI
    }
    RBRACE
  }
}
