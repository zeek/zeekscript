COMMENT-LEADING "# 3 ifs but one too long: should NOT inline any."
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "h"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"a\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "y"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"b\""
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "some_very_long_condition_that_pushes_past_the_limit"
      RPAREN
      BODY {
        SAME-LINE
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"this_long_value\""
          SEMI
        }
      }
    }
    RBRACE
