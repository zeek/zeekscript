FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "NOTICE"
        ARGS {
          LPAREN
          INDEX-LITERAL {
            LBRACKET
            FIELD-ASSIGN "note" {
              IDENTIFIER "Some_Notice"
            }
            COMMA
            FIELD-ASSIGN "conn" {
              IDENTIFIER "c"
            }
            COMMA
            COMMENT-LEADING "# This is a comment about the next field."
            COMMENT-LEADING "# Another comment line."
            FIELD-ASSIGN "identifier" {
              CALL {
                IDENTIFIER "cat"
                ARGS {
                  LPAREN
                  FIELD-ACCESS {
                    IDENTIFIER "id"
                    IDENTIFIER "orig_h"
                  }
                  COMMA
                  FIELD-ACCESS {
                    IDENTIFIER "id"
                    IDENTIFIER "resp_h"
                  }
                  RPAREN
                }
              }
            }
            RBRACKET
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
