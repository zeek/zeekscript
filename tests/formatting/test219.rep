FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "&&" {
        IDENTIFIER "ssl_cache_intermediate_ca"
        OP "&&"
        BINARY-OP "in" {
          IDENTIFIER "issuer_name_hash"
          OP "in"
          IDENTIFIER "intermediate_cache"
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          EXPR-STMT {
            CALL {
              IDENTIFIER "Intel::seen"
              ARGS {
                LPAREN
                INDEX-LITERAL {
                  ARGS {
                    LBRACKET
                    FIELD-ASSIGN "indicator" {
                      DOLLAR
                      ASSIGN "="
                      CALL {
                        IDENTIFIER "HTTP2::build_url"
                        ARGS {
                          LPAREN
                          INDEX {
                            FIELD-ACCESS {
                              FIELD-ACCESS {
                                IDENTIFIER "c"
                                DOLLAR
                                IDENTIFIER "http2_streams"
                              }
                              DOLLAR
                              IDENTIFIER "streams"
                            }
                            SUBSCRIPTS {
                              LBRACKET
                              IDENTIFIER "stream"
                              RBRACKET
                            }
                          }
                          RPAREN
                        }
                      }
                    }
                    COMMA
                    FIELD-ASSIGN "indicator_type" {
                      DOLLAR
                      ASSIGN "="
                      IDENTIFIER "Intel::URL"
                    }
                    COMMA
                    FIELD-ASSIGN "conn" {
                      DOLLAR
                      ASSIGN "="
                      IDENTIFIER "c"
                    }
                    COMMA
                    FIELD-ASSIGN "where" {
                      DOLLAR
                      ASSIGN "="
                      IDENTIFIER "HTTP2::IN_URL"
                    }
                    RBRACKET
                  }
                }
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
