FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "SomeInfo"
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      IDENTIFIER "rec"
      ASSIGN "="
      FIELD-ACCESS {
        IDENTIFIER "c"
        IDENTIFIER "some_rec"
      }
      SEMI
    }
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "?$" {
        BINARY-OP "||" {
          BINARY-OP "||" {
            BINARY-OP "?$" {
              UNARY-OP "!" {
                OP "!"
                IDENTIFIER "rec"
              }
              OP "?$"
              IDENTIFIER "some_field"
            }
            OP "||"
            BINARY-OP "==" {
              UNARY-OP "|...|" {
                OP "|"
                FIELD-ACCESS {
                  IDENTIFIER "rec"
                  IDENTIFIER "some_field"
                }
                OP "|"
              }
              OP "=="
              CONSTANT "0"
            }
          }
          OP "||"
          UNARY-OP "!" {
            OP "!"
            INDEX {
              FIELD-ACCESS {
                IDENTIFIER "rec"
                IDENTIFIER "some_field"
              }
              SUBSCRIPTS {
                LBRACKET
                CONSTANT "0"
                RBRACKET
              }
            }
          }
        }
        OP "?$"
        IDENTIFIER "some_val"
      }
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          IDENTIFIER "ci"
        }
        SEMI
      }
    }
    RBRACE
  }
}
