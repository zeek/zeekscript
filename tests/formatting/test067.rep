FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "SomeInfo"
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "rec"
      ASSIGN "="
      FIELD-ACCESS {
        IDENTIFIER "c"
        DOLLAR
        IDENTIFIER "some_rec"
      }
      SEMI
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      HAS-FIELD {
        BOOL-CHAIN "||" {
          HAS-FIELD {
            NEGATION {
              OP "!"
              IDENTIFIER "rec"
            }
            OP "?$"
            IDENTIFIER "some_field"
          }
          OP "||"
          BINARY-OP "==" {
            CARDINALITY {
              OP "|"
              FIELD-ACCESS {
                IDENTIFIER "rec"
                DOLLAR
                IDENTIFIER "some_field"
              }
              OP "|"
            }
            OP "=="
            CONSTANT "0"
          }
          OP "||"
          NEGATION {
            OP "!"
            INDEX {
              FIELD-ACCESS {
                IDENTIFIER "rec"
                DOLLAR
                IDENTIFIER "some_field"
              }
              SUBSCRIPTS {
                LBRACKET
                CONSTANT "0"
                RBRACKET
              }
            }
          }
        }
        OP "?$"
        IDENTIFIER "some_val"
      }
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          IDENTIFIER "ci"
          SEMI
        }
      }
    }
    RBRACE
  }
}
