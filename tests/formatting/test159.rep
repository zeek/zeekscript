FUNC-DECL "event" "some_event_abc" {
  PARAMS {
    PARAM "host" {
      TYPE-ATOM "addr"
    }
    PARAM "svc" {
      TYPE-ATOM "string"
    }
    PARAM "region" {
      TYPE-ATOM "string"
    }
  }
  BODY {
    LOCAL-DECL "local" "endpoints" {
      INIT "=" {
        TERNARY {
          BINARY-OP ">" {
            IDENTIFIER "some_long_variable_ab"
            CONSTANT "0"
          }
          FIELD-ACCESS {
            IDENTIFIER "calls"
            IDENTIFIER "some_fld"
          }
          CONSTANT "\"Disabled\""
        }
      }
      SEMI
    }
  }
}
