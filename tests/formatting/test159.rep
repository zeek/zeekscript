FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_event_abc"
  PARAMS {
    LPAREN
    PARAM "host" {
      TYPE-ATOM "addr"
    }
    COMMA
    PARAM "svc" {
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "region" {
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      IDENTIFIER "endpoints"
      ASSIGN "="
      TERNARY {
        BINARY-OP ">" {
          IDENTIFIER "some_long_variable_ab"
          OP ">"
          CONSTANT "0"
        }
        QUESTION
        FIELD-ACCESS {
          IDENTIFIER "calls"
          IDENTIFIER "some_fld"
        }
        COLON
        CONSTANT "\"Disabled\""
      }
      SEMI
    }
    RBRACE
  }
}
