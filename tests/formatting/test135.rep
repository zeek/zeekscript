FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      SCHEDULE {
        KEYWORD "schedule"
        SP
        IDENTIFIER "some_time_interval"
        LBRACE
        CALL {
          IDENTIFIER "SomeModule::some_very_long_event_name"
          ARGS {
            LPAREN
            RPAREN
          }
        }
        RBRACE
      }
      SEMI
    }
    RBRACE
  }
}
