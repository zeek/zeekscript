FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "Some::handler"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "is_orig" {
      COLON
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "name" {
      COLON
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "value" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    RBRACE
  }
  COMMENT-TRAILING "#@ NOT-TESTED"
}
