FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "some_services"
      DECL-INIT {
        ASSIGN "="
        BINARY-OP "|" {
          FIELD-ACCESS {
            IDENTIFIER "worker_si"
            DOLLAR
            IDENTIFIER "some_entities"
          }
          OP "|"
          FIELD-ACCESS {
            IDENTIFIER "worker_si"
            DOLLAR
            IDENTIFIER "other_entities"
          }
        }
      }
      SEMI
    }
    RBRACE
  }
}
