FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      IDENTIFIER "some_services"
      ASSIGN "="
      BINARY-OP "|" {
        FIELD-ACCESS {
          IDENTIFIER "worker_si"
          DOLLAR
          IDENTIFIER "some_entities"
        }
        OP "|"
        FIELD-ACCESS {
          IDENTIFIER "worker_si"
          DOLLAR
          IDENTIFIER "other_entities"
        }
      }
      SEMI
    }
    RBRACE
  }
}
