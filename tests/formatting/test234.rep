EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "const"
    SP
    IDENTIFIER "aaaa_bbbbbbbb_cc_ddddddddd"
    DECL-TYPE {
      COLON
      TYPE-PARAMETERIZED "set" {
        SUBSCRIPTS {
          LBRACKET
          TYPE-ATOM "string"
          RBRACKET
        }
      }
    }
    DECL-INIT {
      ASSIGN "="
      CONSTRUCTOR {
        KEYWORD "set"
        ARGS {
          LPAREN
          BLANK
          COMMENT-LEADING "# EEEE (Fff Ggggggg) hhhh ii jjj kkkk ll_mmm nn Oooooo!! pppppp qqqq ?"
          COMMENT-LEADING "# rrrrrrrrrrr.ssss/tt-uuuuuuu/vvvvvvv/wwww/xx/yyyy/111111.zzz?aaa=AaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAaAa=="
          COMMENT-LEADING "#"
          COMMENT-LEADING "# BBBBBBBBBBB,CCCCCC,CCCCCC-DDDDDDDD,EEEE-FFFFF,FFFF 44g8h99i8jk9l1m580"
          COMMENT-LEADING "# n6opq6rs43t0u3v3"
          CONSTANT "\"44g8h99i8jk9l1m580n6opq6rs43t0u3v3\""
          RPAREN
        }
      }
    }
    SEMI
  }
  RBRACE
}
