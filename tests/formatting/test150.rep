FUNC-DECL "function" "f" {
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    SWITCH {
      KEYWORD "switch"
      IDENTIFIER "val"
      LBRACE
      CASE {
        KEYWORD "case"
        VALUES {
          CONSTANT "0"
        }
        COLON
        BODY {
          KEYWORD "break"
          SEMI
        }
      }
      RBRACE
    }
    RBRACE
  }
}
