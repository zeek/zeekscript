GLOBAL-DECL {
  KEYWORD "global"
  IDENTIFIER "some_table"
  COLON
  TYPE-PARAMETERIZED "table" {
    LBRACKET
    TYPE-ATOM "string"
    RBRACKET
    KEYWORD "of"
    TYPE-ATOM "count"
  }
  ATTR-LIST {
    ATTR "&default" {
      ASSIGN "="
      IDENTIFIER "some_long_default_expression_here"
    }
    ATTR "&redef"
  }
  SEMI
}
