GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_table"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "string"
        RBRACKET
      }
      KEYWORD "of"
      SP
      TYPE-ATOM "count"
    }
  }
  ATTR-LIST {
    ATTR "&default" {
      ASSIGN "="
      IDENTIFIER "some_long_default_expression_here"
    }
    ATTR "&redef"
  }
  SEMI
}
