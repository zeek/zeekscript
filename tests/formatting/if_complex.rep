FUNC-DECL-RET {
  KEYWORD "function"
  SP
  IDENTIFIER "some_function_name_aa"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "string"
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "&&" {
        BINARY-OP "&&" {
          HAS-FIELD {
            IDENTIFIER "c"
            OP "?$"
            IDENTIFIER "tunnel"
          }
          OP "&&"
          BINARY-OP ">=" {
            CARDINALITY {
              OP "|"
              FIELD-ACCESS {
                IDENTIFIER "c"
                DOLLAR
                IDENTIFIER "tunnel"
              }
              OP "|"
            }
            OP ">="
            CONSTANT "2"
          }
        }
        OP "&&"
        BINARY-OP "==" {
          FIELD-ACCESS {
            INDEX {
              FIELD-ACCESS {
                IDENTIFIER "c"
                DOLLAR
                IDENTIFIER "tunnel"
              }
              SUBSCRIPTS {
                LBRACKET
                BINARY-OP "-" {
                  CARDINALITY {
                    OP "|"
                    FIELD-ACCESS {
                      IDENTIFIER "c"
                      DOLLAR
                      IDENTIFIER "tunnel"
                    }
                    OP "|"
                  }
                  OP "-"
                  CONSTANT "1"
                }
                RBRACKET
              }
            }
            DOLLAR
            IDENTIFIER "tunnel_type"
          }
          OP "=="
          IDENTIFIER "Tunnel::VXLAN"
        }
      }
      RPAREN
      BODY {
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "\"yep\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
