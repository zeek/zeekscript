GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "some_lookup"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "string"
        RBRACKET
      }
      KEYWORD "of"
      SP
      TYPE-ATOM "string"
    }
  }
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      ARGS {
        LPAREN
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "\"some-key-aa\""
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"val-aa\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "\"some-key-bb\""
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"val-bb\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "\"some-key-cc\""
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"val-cc\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "\"some-key-dd\""
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"val-dd\""
        }
        COMMA
        TRAILING-COMMA
        RPAREN
      }
    }
  }
  ATTR-LIST {
    ATTR "&default" {
      ASSIGN "="
      LAMBDA {
        KEYWORD "function"
        SP
        PARAMS {
          LPAREN
          PARAM "n" {
            COLON
            TYPE-ATOM "string"
          }
          RPAREN
        }
        COLON
        RETURNS {
          TYPE-ATOM "string"
        }
        BODY {
          LBRACE
          RETURN {
            KEYWORD "return"
            SP
            CALL {
              IDENTIFIER "fmt"
              ARGS {
                LPAREN
                CONSTANT "\"fixme-%s\""
                COMMA
                IDENTIFIER "n"
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
  }
  SEMI
}
