FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "val"
      ASSIGN "="
      CALL {
        IDENTIFIER "some_long_func_name"
        ARGS {
          LPAREN
          SLICE {
            IDENTIFIER "data"
            LBRACKET
            BINARY-OP "+" {
              BINARY-OP "-" {
                FIELD-ACCESS {
                  IDENTIFIER "some"
                  DOLLAR
                  IDENTIFIER "off"
                }
                OP "-"
                CONSTANT "1"
              }
              OP "+"
              CONSTANT "8"
            }
            COLON
            BINARY-OP "-" {
              BINARY-OP "+" {
                BINARY-OP "+" {
                  BINARY-OP "-" {
                    FIELD-ACCESS {
                      IDENTIFIER "some"
                      DOLLAR
                      IDENTIFIER "off"
                    }
                    OP "-"
                    CONSTANT "1"
                  }
                  OP "+"
                  CONSTANT "10"
                }
                OP "+"
                BINARY-OP "/" {
                  CONSTANT "23"
                  OP "/"
                  CONSTANT "15"
                }
              }
              OP "-"
              CONSTANT "3"
            }
            RBRACKET
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
