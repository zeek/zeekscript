FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      CALL {
        IDENTIFIER "Cluster::is_enabled"
        ARGS {
          LPAREN
          RPAREN
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          LOCAL-DECL {
            KEYWORD "local"
            SP
            IDENTIFIER "pt"
            DECL-INIT {
              ASSIGN "="
              CALL {
                IDENTIFIER "Cluster::rr_topic"
                ARGS {
                  LPAREN
                  IDENTIFIER "Cluster::proxy_pool"
                  COMMA
                  CONSTANT "\"application-identification\""
                  RPAREN
                }
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
