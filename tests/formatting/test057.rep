EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "global"
    SP
    IDENTIFIER "some_evt"
    COLON
    TYPE-FUNC "event" {
      PARAMS {
        LPAREN
        PARAM "rec" {
          COLON
          TYPE-ATOM "Info"
        }
        RPAREN
      }
    }
    SEMI
  }
  BLANK
  COMMENT-LEADING "## Some trailing comment"
  COMMENT-LEADING "## Another trailing comment"
  RBRACE
}
