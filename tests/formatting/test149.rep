FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      SP
      BINARY-OP "+" {
        BINARY-OP "+" {
          CONSTANT "\"Lovely patio around the fountain. \""
          OP "+"
          CONSTANT "\"Spent a lovely lunch on the patio. \""
        }
        OP "+"
        CONSTANT "\"The menu was inviting and lots of things I wanted to order.\""
      }
      SEMI
    }
    RBRACE
  }
}
