GLOBAL-DECL {
  KEYWORD "global"
  IDENTIFIER "some_tracking_var"
  COLON
  TYPE-PARAMETERIZED "table" {
    LBRACKET
    TYPE-ATOM "count"
    COMMA
    TYPE-ATOM "string"
    RBRACKET
    KEYWORD "of"
    TYPE-ATOM "TrackingRec"
  }
  ATTR-LIST {
    ATTR "&default_insert" {
      ASSIGN "="
      CALL {
        IDENTIFIER "TrackingRec"
        ARGS {
          LPAREN
          FIELD-ASSIGN "field" {
            DOLLAR
            ASSIGN "="
            IDENTIFIER "val"
          }
          RPAREN
        }
      }
    }
    ATTR "&create_expire" {
      ASSIGN "="
      INTERVAL "10" "sec"
    }
    ATTR "&redef"
  }
  SEMI
}
