FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      BINARY-OP "=" {
        FIELD-ACCESS {
          IDENTIFIER "si"
          DOLLAR
          IDENTIFIER "successful_entities"
        }
        OP "="
        BINARY-OP "|" {
          FIELD-ACCESS {
            IDENTIFIER "si"
            DOLLAR
            IDENTIFIER "successful_entities"
          }
          OP "|"
          FIELD-ACCESS {
            IDENTIFIER "worker_si"
            DOLLAR
            IDENTIFIER "successful_entities"
          }
        }
      }
      SEMI
    }
    RBRACE
  }
}
