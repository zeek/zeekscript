FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "aaa"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "bbb"
      RPAREN
      BODY {
        SAME-LINE
        BLOCK {
          LBRACE
          IF-NO-ELSE {
            KEYWORD "if"
            SP
            LPAREN
            BINARY-OP "&&" {
              BINARY-OP "&&" {
                BINARY-OP "==" {
                  IDENTIFIER "ccccc_ddddd_eeeeeeeeee"
                  OP "=="
                  CONSTANT "1"
                }
                OP "&&"
                BINARY-OP "==" {
                  FIELD-ACCESS {
                    INDEX {
                      IDENTIFIER "fffff"
                      SUBSCRIPTS {
                        LBRACKET
                        IDENTIFIER "g"
                        RBRACKET
                      }
                    }
                    DOLLAR
                    IDENTIFIER "hhhh"
                  }
                  OP "=="
                  CONSTANT "\"IIIII-JJJJJJJ\""
                }
              }
              OP "&&"
              BINARY-OP "==" {
                FIELD-ACCESS {
                  INDEX {
                    IDENTIFIER "fffff"
                    SUBSCRIPTS {
                      LBRACKET
                      IDENTIFIER "g"
                      RBRACKET
                    }
                  }
                  DOLLAR
                  IDENTIFIER "kkkkk"
                }
                OP "=="
                CONSTANT "/ll-mmmmm, nn-ooooo, pppp-qqqqqqqqqq/i"
              }
            }
            RPAREN
            BODY {
              EXPR-STMT {
                BINARY-OP "=" {
                  IDENTIFIER "ccccc_ddddd_eeeeeeeeee"
                  OP "="
                  CONSTANT "2"
                }
                SEMI
              }
            }
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
