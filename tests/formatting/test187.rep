FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "test_fn"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "some_condition"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          IF-NO-ELSE {
            KEYWORD "if"
            SP
            LPAREN
            BINARY-OP "in" {
              INDEX-LITERAL {
                ARGS {
                  LBRACKET
                  IDENTIFIER "date"
                  COMMA
                  IDENTIFIER "ip_mask"
                  COMMA
                  IDENTIFIER "resp_p"
                  COMMA
                  IDENTIFIER "p"
                  COMMA
                  IDENTIFIER "corrected_services"
                  COMMA
                  IDENTIFIER "is_server"
                  RBRACKET
                }
              }
              OP "in"
              IDENTIFIER "ns_svc_cache"
            }
            RPAREN
            BODY {
              RETURN-VOID {
                KEYWORD "return"
                SP
                SEMI
              }
            }
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
