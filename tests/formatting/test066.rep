GLOBAL-DECL {
  KEYWORD "global"
  IDENTIFIER "some_long_cache_name"
  COLON
  TYPE-PARAMETERIZED "set" {
    LBRACKET
    TYPE-ATOM "string"
    COMMA
    TYPE-ATOM "subnet"
    COMMA
    TYPE-ATOM "subnet"
    COMMA
    TYPE-ATOM "transport_proto"
    COMMA
    TYPE-ATOM "SomeModule::SomeType"
    RBRACKET
  }
  ATTR-LIST {
    ATTR "&read_expire" {
      IDENTIFIER "cache_interval"
    }
  }
  SEMI
}
