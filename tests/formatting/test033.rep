PREPROC "@ifdef" "SOME_FEATURE" {
  LPAREN
  RPAREN
}
BLANK
FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      IDENTIFIER "some_var"
      SEMI
    }
    RBRACE
  }
}
BLANK
COMMENT-LEADING "# Note: This comment belongs inside the ifdef block."
COMMENT-LEADING "# It should be tab-indented."
PREPROC "@endif"
