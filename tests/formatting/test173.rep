GLOBAL-DECL {
  KEYWORD "global"
  IDENTIFIER "some_table_name_a"
  COLON
  TYPE-PARAMETERIZED "table" {
    LBRACKET
    TYPE-ATOM "count"
    COMMA
    TYPE-ATOM "string"
    RBRACKET
    KEYWORD "of"
    TYPE-ATOM "TrackingRec"
  }
  ATTR-LIST {
    ATTR "&default_insert" {
      CALL {
        IDENTIFIER "TrackingRec"
        ARGS {
          LPAREN
          RPAREN
        }
      }
    }
    ATTR "&create_expire" {
      INTERVAL "10" "sec"
    }
  }
  SEMI
}
