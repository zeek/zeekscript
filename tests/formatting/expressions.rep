RETURN {
  KEYWORD "return"
  SP
  BINARY-OP "&&" {
    BINARY-OP "&&" {
      BINARY-OP "in" {
        IDENTIFIER "a_long_var_name"
        OP "in"
        IDENTIFIER "subj"
      }
      OP "&&"
      BINARY-OP "!in" {
        IDENTIFIER "b_long_var_name"
        OP "!in"
        IDENTIFIER "subj"
      }
    }
    OP "&&"
    BINARY-OP "!in" {
      IDENTIFIER "c_long_var_name"
      OP "!in"
      IDENTIFIER "subj"
    }
  }
  SEMI
}
BLANK
RETURN {
  KEYWORD "return"
  SP
  BINARY-OP "&&" {
    BINARY-OP "in" {
      IDENTIFIER "some_very_long_variable_name"
      OP "in"
      IDENTIFIER "some_other_very_long_variable_name"
    }
    OP "&&"
    BINARY-OP "in" {
      IDENTIFIER "another_thing"
      OP "in"
      IDENTIFIER "yet_another_thing"
    }
  }
  SEMI
}
