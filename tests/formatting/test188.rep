FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    SWITCH {
      KEYWORD "switch"
      SP
      PAREN {
        LPAREN
        IDENTIFIER "n"
        RPAREN
      }
      LBRACE
      CASE {
        KEYWORD "case"
        SP
        VALUES {
          CONSTANT "3"
        }
        COLON
        BODY {
          KW-STMT {
            KEYWORD "break"
            SEMI
          }
        }
      }
      COMMENT-LEADING "#@ BEGIN-NOT-TESTED"
      CASE {
        KEYWORD "case"
        SP
        VALUES {
          CONSTANT "4"
        }
        COLON
        BODY {
          KW-STMT {
            KEYWORD "break"
            SEMI
          }
        }
      }
      COMMENT-LEADING "#@ END-NOT-TESTED"
      RBRACE
    }
    RBRACE
  }
}
