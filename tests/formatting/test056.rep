GLOBAL-DECL {
  KEYWORD "global"
  IDENTIFIER "some_event_decl"
  COLON
  TYPE-FUNC "event" {
    PARAMS {
      LPAREN
      PARAM "o" {
        TYPE-ATOM "string"
      }
      PARAM "label" {
        TYPE-ATOM "string"
      }
      PARAM "conf" {
        TYPE-ATOM "score"
      }
      PARAM "sources" {
        TYPE-PARAMETERIZED "set" {
          LBRACKET
          TYPE-ATOM "string"
          RBRACKET
        }
      }
      PARAM "caller" {
        TYPE-ATOM "string"
      }
      RPAREN
    }
  }
  SEMI
}
