FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "some_function_name_aa"
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "string"
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "&&" {
        BINARY-OP "&&" {
          BINARY-OP "?$" {
            IDENTIFIER "c"
            OP "?$"
            IDENTIFIER "tunnel"
          }
          OP "&&"
          BINARY-OP ">=" {
            UNARY-OP "|...|" {
              OP "|"
              FIELD-ACCESS {
                IDENTIFIER "c"
                IDENTIFIER "tunnel"
              }
              OP "|"
            }
            OP ">="
            CONSTANT "2"
          }
        }
        OP "&&"
        BINARY-OP "==" {
          FIELD-ACCESS {
            INDEX {
              FIELD-ACCESS {
                IDENTIFIER "c"
                IDENTIFIER "tunnel"
              }
              SUBSCRIPTS {
                LBRACKET
                BINARY-OP "-" {
                  UNARY-OP "|...|" {
                    OP "|"
                    FIELD-ACCESS {
                      IDENTIFIER "c"
                      IDENTIFIER "tunnel"
                    }
                    OP "|"
                  }
                  OP "-"
                  CONSTANT "1"
                }
                RBRACKET
              }
            }
            IDENTIFIER "tunnel_type"
          }
          OP "=="
          IDENTIFIER "Tunnel::VXLAN"
        }
      }
      RPAREN
      BODY {
        PRINT {
          KEYWORD "print"
          CONSTANT "\"yep\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
