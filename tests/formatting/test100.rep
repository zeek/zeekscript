FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func_bb"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "cnt" {
      COLON
      TYPE-ATOM "count"
    }
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "interval"
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "some_long_variable_a"
      DECL-INIT {
        ASSIGN "="
        CALL {
          IDENTIFIER "double_to_count"
          ARGS {
            LPAREN
            CALL {
              IDENTIFIER "floor"
              ARGS {
                LPAREN
                DIV {
                  FIELD-ACCESS {
                    FIELD-ACCESS {
                      IDENTIFIER "c"
                      DOLLAR
                      IDENTIFIER "orig"
                    }
                    DOLLAR
                    IDENTIFIER "size"
                  }
                  OP "/"
                  IDENTIFIER "some_long_variable_bb"
                }
                RPAREN
              }
            }
            RPAREN
          }
        }
      }
      SEMI
    }
    RBRACE
  }
}
