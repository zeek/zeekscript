FUNC-DECL "function" "some_func_bb" {
  PARAMS {
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    PARAM "cnt" {
      TYPE-ATOM "count"
    }
  }
  RETURNS {
    TYPE-ATOM "interval"
  }
  BODY {
    LOCAL-DECL "local" "some_long_variable_a" {
      INIT "=" {
        CALL {
          IDENTIFIER "double_to_count"
          ARGS {
            CALL {
              IDENTIFIER "floor"
              ARGS {
                BINARY-OP "/" {
                  FIELD-ACCESS {
                    FIELD-ACCESS {
                      IDENTIFIER "c"
                      IDENTIFIER "orig"
                    }
                    IDENTIFIER "size"
                  }
                  IDENTIFIER "some_long_variable_bb"
                }
              }
            }
          }
        }
      }
      SEMI
    }
  }
}
