FUNC-DECL "function" "some_func_bb" {
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    PARAM "cnt" {
      TYPE-ATOM "count"
    }
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "interval"
  }
  BODY {
    LBRACE
    LOCAL-DECL "local" "some_long_variable_a" {
      ASSIGN "="
      CALL {
        IDENTIFIER "double_to_count"
        ARGS {
          LPAREN
          CALL {
            IDENTIFIER "floor"
            ARGS {
              LPAREN
              BINARY-OP "/" {
                FIELD-ACCESS {
                  FIELD-ACCESS {
                    IDENTIFIER "c"
                    IDENTIFIER "orig"
                  }
                  IDENTIFIER "size"
                }
                OP "/"
                IDENTIFIER "some_long_variable_bb"
              }
              RPAREN
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
