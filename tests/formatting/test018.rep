FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "name" {
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "value" {
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "prefix" {
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "==" {
        IDENTIFIER "name"
        OP "=="
        CONSTANT "\"some-type\""
      }
      RPAREN
      BODY {
        EXPR-STMT {
          CALL {
            IDENTIFIER "some_handler"
            ARGS {
              LPAREN
              IDENTIFIER "c"
              COMMA
              IDENTIFIER "value"
              COMMA
              BINARY-OP "+" {
                IDENTIFIER "prefix"
                OP "+"
                CONSTANT "\"-sfx\""
              }
              RPAREN
            }
          }
          SEMI
        }
        COMMENT-TRAILING "#@ NOT-TESTED"
      }
      BLANK
      ELSE {
        KEYWORD "else"
        IF {
          KEYWORD "if"
          LPAREN
          BINARY-OP "==" {
            IDENTIFIER "name"
            OP "=="
            CONSTANT "\"other-type\""
          }
          RPAREN
          BODY {
            EXPR-STMT {
              CALL {
                IDENTIFIER "other_handler"
                ARGS {
                  LPAREN
                  IDENTIFIER "c"
                  COMMA
                  IDENTIFIER "value"
                  COMMA
                  BINARY-OP "+" {
                    IDENTIFIER "prefix"
                    OP "+"
                    CONSTANT "\"-sfx\""
                  }
                  RPAREN
                }
              }
              SEMI
            }
          }
        }
      }
    }
    RBRACE
  }
}
