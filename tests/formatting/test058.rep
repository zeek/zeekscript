FUNC-DECL "function" "some_func" {
  BODY {
    IF {
      COND {
        BINARY-OP "&&" {
          BINARY-OP "?$" {
            BINARY-OP "&&" {
              BINARY-OP "&&" {
                IDENTIFIER "some_long_var_aa"
                BINARY-OP "==" {
                  FIELD-ACCESS {
                    IDENTIFIER "some_var"
                    IDENTIFIER "some_field"
                  }
                  CONSTANT "\"ok\""
                }
              }
              IDENTIFIER "other"
            }
            IDENTIFIER "some_chain"
          }
          BINARY-OP ">" {
            UNARY-OP "|...|" {
              FIELD-ACCESS {
                IDENTIFIER "other"
                IDENTIFIER "some_chain"
              }
            }
            CONSTANT "2"
          }
        }
      }
      BODY {
        BLOCK {
        }
      }
    }
  }
}
