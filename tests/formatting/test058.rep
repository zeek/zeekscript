FUNC-DECL "function" "some_func" {
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "&&" {
        BINARY-OP "?$" {
          BINARY-OP "&&" {
            BINARY-OP "&&" {
              IDENTIFIER "some_long_var_aa"
              OP "&&"
              BINARY-OP "==" {
                FIELD-ACCESS {
                  IDENTIFIER "some_var"
                  IDENTIFIER "some_field"
                }
                OP "=="
                CONSTANT "\"ok\""
              }
            }
            OP "&&"
            IDENTIFIER "other"
          }
          OP "?$"
          IDENTIFIER "some_chain"
        }
        OP "&&"
        BINARY-OP ">" {
          UNARY-OP "|...|" {
            OP "|"
            FIELD-ACCESS {
              IDENTIFIER "other"
              IDENTIFIER "some_chain"
            }
            OP "|"
          }
          OP ">"
          CONSTANT "2"
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          RBRACE
        }
      }
    }
    RBRACE
  }
}
