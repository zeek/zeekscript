FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BOOL-CHAIN "&&" {
        HAS-FIELD {
          BOOL-CHAIN "&&" {
            IDENTIFIER "some_long_var_aa"
            OP "&&"
            BINARY-OP "==" {
              FIELD-ACCESS {
                IDENTIFIER "some_var"
                DOLLAR
                IDENTIFIER "some_field"
              }
              OP "=="
              CONSTANT "\"ok\""
            }
            OP "&&"
            IDENTIFIER "other"
          }
          OP "?$"
          IDENTIFIER "some_chain"
        }
        OP "&&"
        BINARY-OP ">" {
          UNARY-OP "|...|" {
            OP "|"
            FIELD-ACCESS {
              IDENTIFIER "other"
              DOLLAR
              IDENTIFIER "some_chain"
            }
            OP "|"
          }
          OP ">"
          CONSTANT "2"
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          RBRACE
        }
      }
    }
    RBRACE
  }
}
