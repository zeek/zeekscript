IF {
  COND {
    BINARY-OP "&&" {
      BINARY-OP "?$" {
        BINARY-OP "&&" {
          BINARY-OP "&&" {
            IDENTIFIER "some_long_bool_variable_a"
            BINARY-OP "==" {
              FIELD-ACCESS {
                IDENTIFIER "result"
                IDENTIFIER "result_string"
              }
              CONSTANT "\"ok\""
            }
          }
          IDENTIFIER "result"
        }
        IDENTIFIER "chain_certs"
      }
      BINARY-OP ">" {
        UNARY-OP "|...|" {
          FIELD-ACCESS {
            IDENTIFIER "result"
            IDENTIFIER "chain_certs"
          }
        }
        CONSTANT "2"
      }
    }
  }
  BODY {
    PRINT {
      CONSTANT "\"x\""
      SEMI
    }
  }
}
