FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      SCHEDULE {
        KEYWORD "schedule"
        SP
        IDENTIFIER "xxxx_xxxxxx_xxxx_xxxxxxxx"
        LBRACE
        CALL {
          IDENTIFIER "XxxxXxxxxxxXxxxXxxxx::xxxx_xxxx_xxxxx_xxxx_xxxx"
          ARGS {
            LPAREN
            IDENTIFIER "xxxxxxxx_xxx"
            COMMA
            IDENTIFIER "xxxxxxxx_xxx"
            COMMA
            IDENTIFIER "xxxxxxxx_xxxxx"
            RPAREN
          }
        }
        RBRACE
      }
      SEMI
    }
    RBRACE
  }
}
