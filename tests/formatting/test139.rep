EXPORT {
  TYPE-DECL "SomeAttrs" {
    KEYWORD "type"
    COLON
    TYPE-RECORD {
      FIELD "some_strings" {
        COLON
        TYPE-PARAMETERIZED "set" {
          LBRACKET
          TYPE-ATOM "string"
          RBRACKET
        }
        ATTR-LIST {
          ATTR "&log"
          ATTR "&optional"
        }
      }
      COMMENT-TRAILING "# A set of associated strings"
    }
    SEMI
  }
}
