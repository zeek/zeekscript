FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    SWITCH {
      KEYWORD "switch"
      SP
      IDENTIFIER "val"
      LBRACE
      CASE {
        KEYWORD "case"
        SP
        VALUES {
          CONSTANT "0"
        }
        COLON
        BODY {
          KW-STMT {
            KEYWORD "break"
            SEMI
          }
        }
      }
      RBRACE
    }
    RBRACE
  }
}
