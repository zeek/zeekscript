FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "Log::write"
        ARGS {
          LPAREN
          IDENTIFIER "NS_LOG"
          COMMA
          CALL {
            IDENTIFIER "NS_ServersService"
            ARGS {
              LPAREN
              FIELD-ASSIGN "date" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "date"
              }
              COMMA
              FIELD-ASSIGN "ip_mask" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "ip_mask"
              }
              COMMA
              FIELD-ASSIGN "resp_p" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "resp_p"
              }
              COMMA
              FIELD-ASSIGN "proto" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "p"
              }
              COMMA
              FIELD-ASSIGN "service" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "corrected_services"
              }
              COMMA
              FIELD-ASSIGN "is_server" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "is_server"
              }
              COMMA
              FIELD-ASSIGN "uid" {
                DOLLAR
                ASSIGN "="
                FIELD-ACCESS {
                  IDENTIFIER "c"
                  DOLLAR
                  IDENTIFIER "uid"
                }
              }
              RPAREN
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
