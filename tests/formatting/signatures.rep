FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_handler"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "is_orig" {
      COLON
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "payload" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    ADD {
      KEYWORD "add"
      SP
      INDEX {
        FIELD-ACCESS {
          IDENTIFIER "c"
          DOLLAR
          IDENTIFIER "app"
        }
        SUBSCRIPTS {
          LBRACKET
          CONSTANT "\"test\""
          RBRACKET
        }
      }
      SEMI
    }
    RBRACE
  }
  COMMENT-TRAILING "#@ NOT-TESTED"
}
