EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  COMMENT-LEADING "## Documentation comment."
  TYPEDECL-ENUM "Foo" {
    KEYWORD "type"
    SP
    IDENTIFIER "Foo"
    COLON
    SP
    TYPE-ENUM {
      KEYWORD "enum"
      SP
      LBRACE
      ENUM-VALUE "AAA"
      COMMA
      COMMENT-TRAILING "##< Trailing comment on AAA"
      ENUM-VALUE "BBB"
      COMMENT-TRAILING "##< Trailing comment on BBB"
      RBRACE
    }
    SEMI
  }
  RBRACE
}
