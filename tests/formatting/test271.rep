FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    SWITCH {
      KEYWORD "switch"
      SP
      IDENTIFIER "aaa"
      LBRACE
      CASE {
        KEYWORD "case"
        SP
        VALUES {
          IDENTIFIER "bbb"
        }
        COLON
        BODY {
          RETURN-VOID {
            KEYWORD "return"
            SP
            SEMI
          }
        }
      }
      CASE {
        KEYWORD "case"
        SP
        VALUES {
          IDENTIFIER "ccc"
          COMMA
          IDENTIFIER "ddd"
        }
        COLON
        BODY {
          PRINT {
            KEYWORD "print"
            SP
            CONSTANT "\"aaa\""
            SEMI
          }
        }
      }
      DEFAULT {
        KEYWORD "default"
        COLON
        BODY {
          KW-STMT {
            KEYWORD "break"
            SEMI
          }
        }
      }
      RBRACE
    }
    RBRACE
  }
}
