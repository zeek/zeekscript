BLANK
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    FOR {
      KEYWORD "for"
      SP
      LPAREN
      FOR-COND {
        IDENTIFIER "x"
        KEYWORD "in"
        IDENTIFIER "xs"
      }
      RPAREN
      BODY {
        FOR {
          KEYWORD "for"
          SP
          LPAREN
          FOR-COND {
            IDENTIFIER "y"
            KEYWORD "in"
            IDENTIFIER "ys"
          }
          RPAREN
          BODY {
            EXPR-STMT {
              BINARY-OP "=" {
                INDEX {
                  IDENTIFIER "some_long_table"
                  SUBSCRIPTS {
                    LBRACKET
                    IDENTIFIER "some_key"
                    RBRACKET
                  }
                }
                OP "="
                CALL {
                  IDENTIFIER "SomeFunc"
                  ARGS {
                    LPAREN
                    FIELD-ASSIGN "field_a" {
                      DOLLAR
                      ASSIGN "="
                      IDENTIFIER "val_a"
                    }
                    COMMA
                    FIELD-ASSIGN "field_b" {
                      DOLLAR
                      ASSIGN "="
                      IDENTIFIER "val_b"
                    }
                    RPAREN
                  }
                }
              }
              SEMI
            }
          }
        }
      }
    }
    RBRACE
  }
}
