FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    WHILE {
      KEYWORD "while"
      SP
      LPAREN
      BINARY-OP "&&" {
        BINARY-OP "&&" {
          BINARY-OP "&&" {
            BINARY-OP "<" {
              IDENTIFIER "aaaa_aaaaa_aaaaaa"
              OP "<"
              CONSTANT "200"
            }
            OP "&&"
            BINARY-OP "==" {
              IDENTIFIER "aaaa_aaaaaaa"
              OP "=="
              CONSTANT "0"
            }
          }
          OP "&&"
          BINARY-OP "-" {
            BINARY-OP "<" {
              IDENTIFIER "a"
              OP "<"
              IDENTIFIER "a"
            }
            OP "-"
            CONSTANT "5"
          }
        }
        OP "&&"
        BINARY-OP "<" {
          IDENTIFIER "a"
          OP "<"
          CONSTANT "30"
        }
      }
      RPAREN
      BODY {
        SEMI
      }
    }
    RBRACE
  }
}
