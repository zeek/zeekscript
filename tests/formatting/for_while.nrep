            FIELD-ACCESS {
              IDENTIFIER "result"
              DOLLAR
              IDENTIFIER "some_uids_with_a_very_long_field_name_that_forces_wrapping"
            }
          }
          RPAREN
          BODY {
            LOCAL-DECL {
              KEYWORD "local"
              SP
              IDENTIFIER "x"
              DECL-INIT {
                ASSIGN "="
