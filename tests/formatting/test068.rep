PREPROC "@ifdef" "SOME_FEATURE"
FUNC-DECL "event" "SomeModule::some_esp_message" {
  PARAMS {
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    PARAM "is_orig" {
      TYPE-ATOM "bool"
    }
    PARAM "msg" {
      TYPE-ATOM "SomeModule::SomeEspMsg"
    }
  }
  ATTR-LIST {
    ATTR "&group" {
      IDENTIFIER "MyPkg_SomeEvtGroup"
    }
  }
  BODY {
    EXPR-STMT {
      CALL {
        IDENTIFIER "shuntit"
        ARGS {
          IDENTIFIER "c"
        }
      }
      SEMI
    }
  }
}
PREPROC "@endif"
