PREPROC "@ifdef" "SOME_FEATURE"
FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "SomeModule::some_esp_message"
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "is_orig" {
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "msg" {
      TYPE-ATOM "SomeModule::SomeEspMsg"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      IDENTIFIER "MyPkg_SomeEvtGroup"
    }
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "shuntit"
        ARGS {
          LPAREN
          IDENTIFIER "c"
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
PREPROC "@endif"
