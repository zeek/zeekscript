IF-NO-ELSE {
  KEYWORD "if"
  SP
  LPAREN
  BOOL-CHAIN "&&" {
    HAS-FIELD {
      BOOL-CHAIN "&&" {
        IDENTIFIER "some_long_bool_variable_a"
        OP "&&"
        BINARY-OP "==" {
          FIELD-ACCESS {
            IDENTIFIER "result"
            DOLLAR
            IDENTIFIER "result_string"
          }
          OP "=="
          CONSTANT "\"ok\""
        }
        OP "&&"
        IDENTIFIER "result"
      }
      OP "?$"
      IDENTIFIER "chain_certs"
    }
    OP "&&"
    BINARY-OP ">" {
      CARDINALITY {
        OP "|"
        FIELD-ACCESS {
          IDENTIFIER "result"
          DOLLAR
          IDENTIFIER "chain_certs"
        }
        OP "|"
      }
      OP ">"
      CONSTANT "2"
    }
  }
  RPAREN
  BODY {
    SAME-LINE
    PRINT {
      KEYWORD "print"
      SP
      CONSTANT "\"x\""
      SEMI
    }
  }
}
