FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "a" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "b" {
      COLON
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "rec" {
      COLON
      TYPE-ATOM "SomeRec"
    }
    RPAREN
  }
  BODY {
    LBRACE
    COMMENT-LEADING "#@ BEGIN-SKIP-TESTING"
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "in" {
        IDENTIFIER "rec"
        OP "in"
        IDENTIFIER "did_check"
      }
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SEMI
        }
      }
    }
    COMMENT-LEADING "#@ END-SKIP-TESTING"
    BLANK
    EXPR-STMT {
      CALL {
        IDENTIFIER "next_thing"
        ARGS {
          LPAREN
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
