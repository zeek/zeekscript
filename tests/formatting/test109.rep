FUNC-DECL "function" "some_func" {
  PARAMS {
    PARAM "a" {
      TYPE-ATOM "count"
    }
    PARAM "b" {
      TYPE-ATOM "string"
    }
    PARAM "rec" {
      TYPE-ATOM "SomeRec"
    }
  }
  BODY {
    COMMENT-LEADING "#@ BEGIN-SKIP-TESTING"
    IF {
      COND {
        BINARY-OP "in" {
          IDENTIFIER "rec"
          IDENTIFIER "did_check"
        }
      }
      BODY {
        RETURN
        SEMI
      }
    }
    COMMENT-LEADING "#@ END-SKIP-TESTING"
    BLANK
    EXPR-STMT {
      CALL {
        IDENTIFIER "next_thing"
      }
      SEMI
    }
  }
}
