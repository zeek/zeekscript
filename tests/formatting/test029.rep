PREPROC-COND "@ifdef" "SOME_FEATURE" {
  LPAREN
  RPAREN
}
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      SP
      IDENTIFIER "some_var"
      SEMI
    }
    RBRACE
  }
}
BLANK
COMMENT-LEADING "# Fallback path below."
PREPROC "@else"
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      SP
      CONSTANT "\"other\""
      SEMI
    }
    RBRACE
  }
}
BLANK
PREPROC "@endif"
