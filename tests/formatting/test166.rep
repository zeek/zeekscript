FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    FOR {
      KEYWORD "for"
      SP
      LPAREN
      VARS {
        IDENTIFIER "val"
      }
      KEYWORD "in"
      SP
      ITERABLE {
        IDENTIFIER "some_set"
      }
      RPAREN
      BODY {
        KEYWORD "next"
        SEMI
      }
    }
    COMMENT-TRAILING "# skip it"
    RBRACE
  }
}
