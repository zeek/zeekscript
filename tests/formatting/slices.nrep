BLANK
EXPR-STMT {
  SLICE-PARTIAL {
    IDENTIFIER "data"
    LBRACKET
    CALL {
      IDENTIFIER "f"
      ARGS {
        LPAREN
        RPAREN
      }
    }
    COLON
    CONSTANT ""
    RBRACKET
  }
  SEMI
}
