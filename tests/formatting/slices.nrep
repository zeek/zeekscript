COMMENT-LEADING "# Slice expressions: all variants of [start:end] with expressions, empty bounds, and function calls."
COMMENT-LEADING "# test070.zeek"
COMMENT-LEADING "# test071.zeek"
COMMENT-LEADING "# test072.zeek"
COMMENT-LEADING "# test073.zeek"
COMMENT-LEADING "# test074.zeek"
COMMENT-LEADING "# test075.zeek"
COMMENT-LEADING "# test076.zeek"
COMMENT-LEADING "# test077.zeek"
COMMENT-LEADING "# test078.zeek"
COMMENT-LEADING "# test101.zeek"
BLANK
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "val"
      DECL-INIT {
        ASSIGN "="
        CALL {
          IDENTIFIER "some_long_func_name"
          ARGS {
            LPAREN
            SLICE {
              IDENTIFIER "data"
              LBRACKET
              BINARY-OP "+" {
                BINARY-OP "-" {
                  FIELD-ACCESS {
                    IDENTIFIER "some"
                    DOLLAR
                    IDENTIFIER "off"
                  }
                  OP "-"
                  CONSTANT "1"
                }
                OP "+"
                CONSTANT "8"
              }
              COLON
              BINARY-OP "-" {
                BINARY-OP "+" {
                  BINARY-OP "+" {
                    BINARY-OP "-" {
                      FIELD-ACCESS {
                        IDENTIFIER "some"
                        DOLLAR
                        IDENTIFIER "off"
                      }
                      OP "-"
                      CONSTANT "1"
                    }
                    OP "+"
                    CONSTANT "10"
                  }
                  OP "+"
                  DIV {
                    CONSTANT "23"
                    OP "/"
                    CONSTANT "15"
                  }
                }
                OP "-"
                CONSTANT "3"
              }
              RBRACKET
            }
            RPAREN
          }
        }
      }
      SEMI
    }
    RBRACE
  }
}
BLANK
EXPR-STMT {
  SLICE {
    IDENTIFIER "xs"
    LBRACKET
    CONSTANT "0"
    COLON
    CONSTANT "1"
    RBRACKET
  }
  SEMI
}
BLANK
EXPR-STMT {
  SLICE-PARTIAL {
    IDENTIFIER "xs"
    LBRACKET
    CONSTANT "0"
    COLON
    CONSTANT ""
    RBRACKET
  }
  SEMI
}
BLANK
EXPR-STMT {
  SLICE-PARTIAL {
    IDENTIFIER "xs"
    LBRACKET
    CONSTANT ""
    COLON
    CONSTANT "1"
    RBRACKET
  }
  SEMI
}
BLANK
EXPR-STMT {
  SLICE-PARTIAL {
    IDENTIFIER "data"
    LBRACKET
    BINARY-OP "-" {
      CONSTANT "1"
      OP "-"
      CONSTANT "1"
    }
    COLON
    CONSTANT ""
    RBRACKET
  }
  SEMI
}
BLANK
EXPR-STMT {
  SLICE-PARTIAL {
