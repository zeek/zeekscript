FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      SCHEDULE {
        KEYWORD "schedule"
        SP
        INTERVAL "10" "secs"
        LBRACE
        CALL {
          IDENTIFIER "Xxxxxxxxxxxx::xxx_xxxxxxx_xxxxx_xxxxxxxxx_xxx_xxxxxxxxx"
          ARGS {
            LPAREN
            RPAREN
          }
        }
        RBRACE
      }
      SEMI
    }
    RBRACE
  }
}
