FUNC-DECL "function" "foo" {
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      CALL {
        IDENTIFIER "Cluster::is_enabled"
        ARGS {
          LPAREN
          RPAREN
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          BLANK
          LOCAL-DECL "local" "pt" {
            ASSIGN "="
            CALL {
              IDENTIFIER "Cluster::rr_topic"
              ARGS {
                LPAREN
                IDENTIFIER "Cluster::proxy_pool"
                COMMA
                CONSTANT "\"application-identification\""
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
