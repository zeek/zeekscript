FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "||" {
        BINARY-OP "||" {
          BINARY-OP "||" {
            BINARY-OP "||" {
              BINARY-OP "<" {
                IDENTIFIER "s0"
                OP "<"
                CONSTANT "0"
              }
              OP "||"
              BINARY-OP ">" {
                IDENTIFIER "s1"
                OP ">"
                CONSTANT "0"
              }
            }
            OP "||"
            BINARY-OP "<" {
              IDENTIFIER "s2"
              OP "<"
              CONSTANT "0"
            }
          }
          OP "||"
          BINARY-OP ">" {
            IDENTIFIER "s3"
            OP ">"
            CONSTANT "0"
          }
        }
        OP "||"
        BINARY-OP "<" {
          IDENTIFIER "s4"
          OP "<"
          CONSTANT "0"
        }
      }
      RPAREN
      BODY {
        EXPR-STMT {
          CALL {
            IDENTIFIER "foo"
            ARGS {
              LPAREN
              RPAREN
            }
          }
          SEMI
        }
      }
    }
    RBRACE
  }
}
