FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      UNARY-OP "!" {
        OP "!"
        CALL {
          IDENTIFIER "some_function_name"
          ARGS {
            LPAREN
            IDENTIFIER "some_argument"
            COMMA
            IDENTIFIER "new_file"
            COMMA
            IDENTIFIER "extra_vals"
            COMMA
            IDENTIFIER "some_uids"
            COMMA
            IDENTIFIER "some_ids"
            COMMA
            TERNARY {
              FIELD-ACCESS {
                IDENTIFIER "info"
                IDENTIFIER "source"
              }
              QUESTION
              FIELD-ACCESS {
                IDENTIFIER "info"
                IDENTIFIER "source"
              }
              COLON
              CONSTANT "\"\""
            }
            COMMA
            TERNARY {
              FIELD-ACCESS {
                IDENTIFIER "info"
                IDENTIFIER "mime"
              }
              QUESTION
              FIELD-ACCESS {
                IDENTIFIER "info"
                IDENTIFIER "mime"
              }
              COLON
              CONSTANT "\"\""
            }
            COMMA
            TERNARY {
              FIELD-ACCESS {
                IDENTIFIER "info"
                IDENTIFIER "md5"
              }
              QUESTION
              FIELD-ACCESS {
                IDENTIFIER "info"
                IDENTIFIER "md5"
              }
              COLON
              CONSTANT "\"\""
            }
            RPAREN
          }
        }
      }
      RPAREN
      BODY {
        PRINT {
          KEYWORD "print"
          CONSTANT "\"failed\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
