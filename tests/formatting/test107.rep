FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      IDENTIFIER "next_orig_multiplier"
      ASSIGN "="
      CALL {
        IDENTIFIER "double_to_count"
        ARGS {
          LPAREN
          CALL {
            IDENTIFIER "floor"
            ARGS {
              LPAREN
              BINARY-OP "/" {
                FIELD-ACCESS {
                  FIELD-ACCESS {
                    IDENTIFIER "c"
                    IDENTIFIER "orig"
                  }
                  IDENTIFIER "size"
                }
                OP "/"
                IDENTIFIER "size_threshold_in_bytes"
              }
              RPAREN
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
