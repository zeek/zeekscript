FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "some_fn"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      IDENTIFIER "info"
      ASSIGN "="
      CALL {
        IDENTIFIER "SomeModule::SomeFn"
        ARGS {
          LPAREN
          FIELD-ASSIGN "note" {
            IDENTIFIER "Found"
          }
          COMMA
          FIELD-ASSIGN "uid" {
            IDENTIFIER "uid"
          }
          COMMA
          FIELD-ASSIGN "msg" {
            CALL {
              IDENTIFIER "fmt"
              ARGS {
                LPAREN
                CONSTANT "\"%s found on %s entity using %s item.\""
                COMMA
                IDENTIFIER "usecase_desc"
                COMMA
                IDENTIFIER "orig_entity"
                COMMA
                IDENTIFIER "item"
                RPAREN
              }
            }
          }
          COMMA
          FIELD-ASSIGN "sub" {
            CALL {
              IDENTIFIER "fmt"
              ARGS {
                LPAREN
                CONSTANT "\"Score: %s. Days: %s\""
                COMMA
                IDENTIFIER "item_score"
                COMMA
                IDENTIFIER "history_days"
                RPAREN
              }
            }
          }
          COMMA
          FIELD-ASSIGN "identifier" {
            CALL {
              IDENTIFIER "cat"
              ARGS {
                LPAREN
                IDENTIFIER "orig_entity"
                COMMA
                IDENTIFIER "usecase"
                COMMA
                IDENTIFIER "item"
                RPAREN
              }
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
