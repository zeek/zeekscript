FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_event"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "some_func"
        ARGS {
          LPAREN
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              FIELD-ASSIGN "aa" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "BB"
              }
              COMMA
              FIELD-ASSIGN "cc" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "dd"
              }
              COMMA
              COMMENT-TRAILING "#@ SOME-TAG"
              FIELD-ASSIGN "ee" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "ff"
              }
              RBRACKET
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
