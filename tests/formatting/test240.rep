GLOBAL-DECL {
  KEYWORD "redef"
  SP
  IDENTIFIER "aaa_bbb"
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "set"
      ARGS {
        LPAREN
        CONSTANT "\"ccc ccc\""
        COMMA
        CONSTANT "\"Ddd\""
        COMMA
        CONSTANT "\"Eee eee\""
        COMMA
        CONSTANT "\"Ffff ggggg hhhh iiiii\""
        COMMA
        COMMENT-TRAILING "# JJJ"
        TRAILING-COMMA
        RPAREN
      }
    }
  }
  SEMI
}
