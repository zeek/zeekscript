FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "val" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "==" {
        IDENTIFIER "some_pattern"
        OP "=="
        IDENTIFIER "val"
      }
      RPAREN
      BODY {
        EXPR-STMT {
          BINARY-OP "=" {
            IDENTIFIER "result"
            OP "="
            CONSTANT "\"found\""
          }
          SEMI
        }
      }
      BLANK
      COMMENT-LEADING "# This handles the fallback case."
      COMMENT-LEADING "# Check secondary pattern too."
      ELSE {
        KEYWORD "else"
        IF {
          KEYWORD "if"
          LPAREN
          BINARY-OP "==" {
            IDENTIFIER "other_pattern"
            OP "=="
            IDENTIFIER "val"
          }
          RPAREN
          BODY {
            EXPR-STMT {
              BINARY-OP "=" {
                IDENTIFIER "result"
                OP "="
                SLICE {
                  IDENTIFIER "val"
                  LBRACKET
                  BINARY-OP "+" {
                    IDENTIFIER "idx"
                    OP "+"
                    CONSTANT "1"
                  }
                  COLON
                  CONSTANT ""
                  RBRACKET
                }
              }
              SEMI
            }
          }
        }
      }
    }
    RBRACE
  }
}
