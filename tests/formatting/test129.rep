TYPE-DECL "Foo" {
  KEYWORD "type"
  IDENTIFIER "Foo"
  COLON
  TYPE-RECORD {
    KEYWORD "record"
    LBRACE
    FIELD "aa" {
      COLON
      TYPE-ATOM "string"
      ATTR-LIST {
        ATTR "&default" {
          CONSTANT "\"\""
        }
      }
    }
    FIELD "bb" {
      COLON
      TYPE-ATOM "count"
      ATTR-LIST {
        ATTR "&default" {
          CONSTANT "0"
        }
      }
    }
    COMMENT-TRAILING "# a comment"
    BLANK
    FIELD "cc" {
      COLON
      TYPE-ATOM "bool"
    }
    FIELD "dd" {
      COLON
      TYPE-ATOM "bool"
      ATTR-LIST {
        ATTR "&default" {
          CONSTANT "F"
        }
      }
    }
    RBRACE
  }
  SEMI
}
