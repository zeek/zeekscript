TYPE-DECL "Foo" {
  TYPE-RECORD {
    FIELD "aa" {
      TYPE-ATOM "string"
      ATTR-LIST {
        ATTR "&default" {
          CONSTANT "\"\""
        }
      }
    }
    FIELD "bb" {
      TYPE-ATOM "count"
      ATTR-LIST {
        ATTR "&default" {
          CONSTANT "0"
        }
      }
    }
    COMMENT-TRAILING "# a comment"
    BLANK
    FIELD "cc" {
      TYPE-ATOM "bool"
    }
    FIELD "dd" {
      TYPE-ATOM "bool"
      ATTR-LIST {
        ATTR "&default" {
          CONSTANT "F"
        }
      }
    }
  }
  SEMI
}
