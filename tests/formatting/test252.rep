FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "aaaa"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-WITH-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "test"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          PRINT {
            KEYWORD "print"
            SP
            CONSTANT "\"aaaa\""
            SEMI
          }
          RBRACE
        }
        COMMENT-LEADING "#@ END Aaaa::aaaa"
      }
      BLANK
      ELSE-BODY {
        KEYWORD "else"
        SP
        BLOCK {
          LBRACE
          PRINT {
            KEYWORD "print"
            SP
            CONSTANT "\"bbbb\""
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
