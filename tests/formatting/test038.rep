GLOBAL-DECL "const" "some_lookup" {
  COLON
  TYPE-PARAMETERIZED "table" {
    LBRACKET
    TYPE-ATOM "string"
    RBRACKET
    KEYWORD "of"
    TYPE-ATOM "string"
  }
  ASSIGN "="
  CONSTRUCTOR "table" {
    LPAREN
    BINARY-OP "=" {
      INDEX-LITERAL {
        LBRACKET
        CONSTANT "\"some-key-aa\""
        RBRACKET
      }
      OP "="
      CONSTANT "\"val-aa\""
    }
    COMMA
    BINARY-OP "=" {
      INDEX-LITERAL {
        LBRACKET
        CONSTANT "\"some-key-bb\""
        RBRACKET
      }
      OP "="
      CONSTANT "\"val-bb\""
    }
    COMMA
    BINARY-OP "=" {
      INDEX-LITERAL {
        LBRACKET
        CONSTANT "\"some-key-cc\""
        RBRACKET
      }
      OP "="
      CONSTANT "\"val-cc\""
    }
    COMMA
    BINARY-OP "=" {
      INDEX-LITERAL {
        LBRACKET
        CONSTANT "\"some-key-dd\""
        RBRACKET
      }
      OP "="
      CONSTANT "\"val-dd\""
    }
    COMMA
    RPAREN
  }
  ATTR-LIST {
    ATTR "&default" {
      LAMBDA {
        PARAMS {
          LPAREN
          PARAM "n" {
            TYPE-ATOM "string"
          }
          RPAREN
        }
        COLON
        RETURNS {
          TYPE-ATOM "string"
        }
        BODY {
          LBRACE
          RETURN {
            KEYWORD "return"
            CALL {
              IDENTIFIER "fmt"
              ARGS {
                LPAREN
                CONSTANT "\"fixme-%s\""
                COMMA
                IDENTIFIER "n"
                RPAREN
              }
            }
          }
          SEMI
          RBRACE
        }
      }
    }
  }
  SEMI
}
