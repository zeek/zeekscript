FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BOOL-CHAIN "&&" {
        BINARY-OP ">" {
          IDENTIFIER "alpha_val"
          OP ">"
          IDENTIFIER "threshold"
        }
        OP "&&"
        BINARY-OP ">" {
          IDENTIFIER "beta_val"
          OP ">"
          IDENTIFIER "threshold"
        }
        OP "&&"
        BINARY-OP ">" {
          IDENTIFIER "gamma_val"
          OP ">"
          IDENTIFIER "threshold"
        }
        OP "&&"
        BINARY-OP ">" {
          IDENTIFIER "delta_val"
          OP ">"
          IDENTIFIER "threshold"
        }
        OP "&&"
        BINARY-OP ">" {
          IDENTIFIER "epsilon_val"
          OP ">"
          IDENTIFIER "threshold"
        }
        OP "&&"
        BINARY-OP ">" {
          IDENTIFIER "zeta_val"
          OP ">"
          IDENTIFIER "threshold"
        }
      }
      RPAREN
      BODY {
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "\"yes\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
