FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-WITH-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "&&" {
        BINARY-OP "in" {
          IDENTIFIER "aaa"
          OP "in"
          IDENTIFIER "bbb"
        }
        OP "&&"
        BINARY-OP "==" {
          IDENTIFIER "ccc"
          OP "=="
          INDEX {
            IDENTIFIER "ddd"
            SUBSCRIPTS {
              LBRACKET
              IDENTIFIER "aaa"
              RBRACKET
            }
          }
        }
      }
      RPAREN
      COMMENT-LEADING "# eee fff ggg"
      BODY {
        SEMI
        COMMENT-TRAILING "#@ NOT-TESTED"
      }
      ELSE-IF {
        KEYWORD "else"
        SP
        IF-WITH-ELSE {
          KEYWORD "if"
          SP
          LPAREN
          BINARY-OP "&&" {
            BINARY-OP "in" {
              CONSTANT "/^hhh/"
              OP "in"
              IDENTIFIER "aaa"
            }
            OP "&&"
            BINARY-OP "==" {
              IDENTIFIER "iii"
              OP "=="
              CONSTANT "443/tcp"
            }
          }
          RPAREN
          COMMENT-LEADING "# jjj - kkk lll mmm nnn ooo ppp 2 qqq"
          BODY {
            SEMI
            COMMENT-TRAILING "#@ NOT-TESTED"
          }
          ELSE-BODY {
            KEYWORD "else"
            SP
            EXPR-STMT {
              CALL {
                IDENTIFIER "rrr"
                ARGS {
                  LPAREN
                  RPAREN
                }
              }
              SEMI
            }
          }
        }
      }
    }
    RBRACE
  }
}
