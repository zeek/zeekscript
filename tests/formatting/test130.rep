FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "Log::create_stream"
        ARGS {
          LPAREN
          IDENTIFIER "SOME_LOG"
          COMMA
          INDEX-LITERAL {
            LBRACKET
            FIELD-ASSIGN "columns" {
              DOLLAR
              ASSIGN "="
              IDENTIFIER "SomeInfo"
            }
            COMMA
            FIELD-ASSIGN "path" {
              DOLLAR
              ASSIGN "="
              CONSTANT "\"some_log_path\""
            }
            COMMA
            FIELD-ASSIGN "policy" {
              DOLLAR
              ASSIGN "="
              IDENTIFIER "some_log_policy"
            }
            RBRACKET
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
