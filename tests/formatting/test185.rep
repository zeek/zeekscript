FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "Log::write"
        ARGS {
          LPAREN
          IDENTIFIER "VPN_TYPE_LOG"
          COMMA
          CALL {
            IDENTIFIER "VPNType"
            ARGS {
              LPAREN
              FIELD-ASSIGN "date" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "date"
              }
              COMMA
              FIELD-ASSIGN "orig_subnet" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "o_s"
              }
              COMMA
              FIELD-ASSIGN "resp_subnet" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "r_s"
              }
              COMMA
              FIELD-ASSIGN "proto" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "proto_str"
              }
              COMMA
              FIELD-ASSIGN "vpn_type" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "vtype_str"
              }
              COMMA
              FIELD-ASSIGN "uid" {
                DOLLAR
                ASSIGN "="
                FIELD-ACCESS {
                  IDENTIFIER "rec"
                  DOLLAR
                  IDENTIFIER "uid"
                }
              }
              RPAREN
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
