FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "test"
      RPAREN
      BODY {
        EXPR-STMT {
          CALL {
            IDENTIFIER "ProtocolAnalyzer::register_packet_handler"
            ARGS {
              LPAREN
              IDENTIFIER "ProtocolAnalyzer::ANALYZER_ROOT"
              COMMA
              IDENTIFIER "DLT_EN10MB"
              COMMA
              IDENTIFIER "handler_tag"
              RPAREN
            }
          }
          SEMI
        }
      }
    }
    RBRACE
  }
}
