GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "tbl"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "count"
        RBRACKET
      }
      KEYWORD "of"
      SP
      TYPE-ATOM "string"
    }
  }
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      ARGS {
        LPAREN
        BINARY-OP "=" {
          INDEX-LITERAL {
            LBRACKET
            CONSTANT "0x00"
            RBRACKET
          }
          OP "="
          CONSTANT "\"AAAA\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            LBRACKET
            CONSTANT "0x01"
            RBRACKET
          }
          OP "="
          CONSTANT "\"BBBB\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            LBRACKET
            CONSTANT "0x02"
            RBRACKET
          }
          OP "="
          CONSTANT "\"CCCC\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            LBRACKET
            CONSTANT "0x03"
            RBRACKET
          }
          OP "="
          CONSTANT "\"DDDD\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            LBRACKET
            CONSTANT "0x04"
            RBRACKET
          }
          OP "="
          CONSTANT "\"EEEE\""
        }
        COMMA
        BINARY-OP "=" {
          INDEX-LITERAL {
            LBRACKET
            CONSTANT "0x05"
            RBRACKET
          }
          OP "="
          CONSTANT "\"FFFF\""
        }
        RPAREN
      }
    }
  }
  SEMI
}
