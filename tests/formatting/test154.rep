FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    FOR {
      KEYWORD "for"
      SP
      LPAREN
      FOR-COND {
        IDENTIFIER "idx"
        KEYWORD "in"
        IDENTIFIER "some_list"
      }
      RPAREN
      COMMENT-TRAILING "# iterate items"
      BODY {
        PRINT {
          KEYWORD "print"
          SP
          IDENTIFIER "idx"
          SEMI
        }
      }
    }
    RBRACE
  }
}
