GLOBAL-DECL "const" "tbl" {
  TYPE {
    TYPE-PARAMETERIZED "table" {
      TYPE-ATOM "count"
      OF
      TYPE-ATOM "string"
    }
  }
  INIT "=" {
    CONSTRUCTOR "table" {
      BINARY-OP "=" {
        INDEX-LITERAL {
          CONSTANT "0x00"
        }
        CONSTANT "\"AAAA\""
      }
      BINARY-OP "=" {
        INDEX-LITERAL {
          CONSTANT "0x01"
        }
        CONSTANT "\"BBBB\""
      }
      BINARY-OP "=" {
        INDEX-LITERAL {
          CONSTANT "0x02"
        }
        CONSTANT "\"CCCC\""
      }
      BINARY-OP "=" {
        INDEX-LITERAL {
          CONSTANT "0x03"
        }
        CONSTANT "\"DDDD\""
      }
      BINARY-OP "=" {
        INDEX-LITERAL {
          CONSTANT "0x04"
        }
        CONSTANT "\"EEEE\""
      }
      BINARY-OP "=" {
        INDEX-LITERAL {
          CONSTANT "0x05"
        }
        CONSTANT "\"FFFF\""
      }
    }
  }
  SEMI
}
