                }
                ATTR-LIST {
                  ATTR "&create_expire" {
                    ASSIGN "="
                    IDENTIFIER "window"
                  }
                }
              }
            }
            COMMA
            FIELD-ASSIGN "bbb" {
              DOLLAR
