EXPR-STMT {
  BINARY-OP "=" {
    INDEX {
      IDENTIFIER "some_table_variable_name"
      SUBSCRIPTS {
        LBRACKET
        IDENTIFIER "some_key"
        RBRACKET
      }
    }
    OP "="
    CALL {
      IDENTIFIER "X509::Result"
      ARGS {
        LPAREN
        FIELD-ASSIGN "result" {
          DOLLAR
          ASSIGN "="
          FIELD-ACCESS {
            IDENTIFIER "result"
            DOLLAR
            IDENTIFIER "result"
          }
        }
        COMMA
        FIELD-ASSIGN "result_string" {
          DOLLAR
          ASSIGN "="
          FIELD-ACCESS {
            IDENTIFIER "result"
            DOLLAR
            IDENTIFIER "result_string"
          }
        }
        RPAREN
      }
    }
  }
  SEMI
}
