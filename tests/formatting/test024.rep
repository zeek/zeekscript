FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_handler"
  PARAMS {
    LPAREN
    PARAM "rec" {
      COLON
      TYPE-ATOM "SomeModule::Info"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "in" {
        INDEX-LITERAL {
          LBRACKET
          IDENTIFIER "aaa"
          COMMA
          IDENTIFIER "bbb"
          COMMA
          IDENTIFIER "ccc"
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            DOLLAR
            IDENTIFIER "source_field"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            DOLLAR
            IDENTIFIER "type_field"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            DOLLAR
            IDENTIFIER "name_field"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            DOLLAR
            IDENTIFIER "orig_flag"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            DOLLAR
            IDENTIFIER "byte_count"
          }
          RBRACKET
        }
        OP "in"
        IDENTIFIER "some_long_cache_name"
      }
      RPAREN
      BODY {
        RETURN-VOID {
          KEYWORD "return"
          SP
          SEMI
        }
      }
    }
    RBRACE
  }
}
