FUNC-DECL "event" "some_handler" {
  PARAMS {
    LPAREN
    PARAM "rec" {
      TYPE-ATOM "SomeModule::Info"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "in" {
        INDEX-LITERAL {
          LBRACKET
          IDENTIFIER "aaa"
          COMMA
          IDENTIFIER "bbb"
          COMMA
          IDENTIFIER "ccc"
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            IDENTIFIER "source_field"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            IDENTIFIER "type_field"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            IDENTIFIER "name_field"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            IDENTIFIER "orig_flag"
          }
          COMMA
          FIELD-ACCESS {
            IDENTIFIER "rec"
            IDENTIFIER "byte_count"
          }
          RBRACKET
        }
        OP "in"
        IDENTIFIER "some_long_cache_name"
      }
      RPAREN
      BODY {
        RETURN
        SEMI
      }
    }
    RBRACE
  }
}
