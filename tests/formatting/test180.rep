EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "option"
    SP
    IDENTIFIER "ignored_hosts"
    DECL-INIT {
      ASSIGN "="
      CONSTRUCTOR {
        KEYWORD "set"
        ARGS {
          LPAREN
          CONSTANT "\"aaa.com\""
          COMMA
          CONSTANT "\"bbb.com\""
          COMMA
          CONSTANT "\"ccc-1.com\""
          COMMA
          CONSTANT "\"ddd.com\""
          COMMA
          CONSTANT "\"eee.com\""
          COMMA
          CONSTANT "\"fff.com\""
          RPAREN
        }
      }
    }
    SEMI
  }
  RBRACE
}
