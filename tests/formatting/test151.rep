FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    SWITCH {
      KEYWORD "switch"
      PAREN {
        LPAREN
        IDENTIFIER "val"
        RPAREN
      }
      LBRACE
      CASE {
        KEYWORD "case"
        VALUES {
          CONSTANT "0"
        }
        COLON
        BODY {
          KEYWORD "break"
          SEMI
        }
      }
      CASE {
        KEYWORD "case"
        VALUES {
          CONSTANT "1"
        }
        COLON
        BODY {
          KEYWORD "break"
          SEMI
        }
      }
      RBRACE
    }
    RBRACE
  }
}
