FUNC-DECL "function" "f" {
  BODY {
    SWITCH {
      EXPR {
        PAREN {
          IDENTIFIER "val"
        }
      }
      CASE {
        VALUES {
          CONSTANT "0"
        }
        BODY {
          BREAK
          SEMI
        }
      }
      CASE {
        VALUES {
          CONSTANT "1"
        }
        BODY {
          BREAK
          SEMI
        }
      }
    }
  }
}
