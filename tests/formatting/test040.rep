GLOBAL-DECL "redef" "some_hosts" {
  ASSIGN "+="
  CALL {
    IDENTIFIER "set"
    ARGS {
      LPAREN
      CONSTANT "\"some.host.example.com\""
      COMMA
      CONSTANT "\"another.longer.hostname.example.org\""
      COMMA
      CONSTANT "\"yet.another.host.example.net\""
      COMMA
      RPAREN
    }
  }
  SEMI
}
