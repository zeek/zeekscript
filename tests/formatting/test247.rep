FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "xxx"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          IF-NO-ELSE {
            KEYWORD "if"
            SP
            LPAREN
            IDENTIFIER "x"
            RPAREN
            BODY {
              BLOCK {
                LBRACE
                EXPR-STMT {
                  CALL {
                    IDENTIFIER "Xxx::xxxxxxxxx"
                    ARGS {
                      LPAREN
                      CONSTANT "\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\""
                      COMMA
                      IDENTIFIER "X"
                      COMMA
                      CONSTANT "\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\""
                      RPAREN
                    }
                  }
                  SEMI
                }
                EXPR-STMT {
                  CALL {
                    IDENTIFIER "Xxx::xxxxxxxxx"
                    ARGS {
                      LPAREN
                      CONSTANT "\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\""
                      COMMA
                      IDENTIFIER "Xxxxxxxxxx::XXX"
                      COMMA
                      CONSTANT "\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\""
                      RPAREN
                    }
                  }
                  SEMI
                }
                RBRACE
              }
            }
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
