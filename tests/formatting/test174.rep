EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  TYPEDECL-RECORD "SomeInfo" {
    KEYWORD "type"
    SP
    IDENTIFIER "SomeInfo"
    COLON
    SP
    TYPE-RECORD {
      KEYWORD "record"
      SP
      LBRACE
      FIELD "some_field_name" {
        COLON
        TYPE-PARAMETERIZED "set" {
          LBRACKET
          TYPE-ATOM "string"
          RBRACKET
        }
        ATTR-LIST {
          ATTR "&log"
          ATTR "&optional"
        }
        SEMI
      }
      COMMENT-TRAILING "# A trailing comment here"
      RBRACE
    }
    SEMI
  }
  RBRACE
}
