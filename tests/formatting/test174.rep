EXPORT {
  TYPE-DECL "SomeInfo" {
    KEYWORD "type"
    COLON
    TYPE-RECORD {
      FIELD "some_field_name" {
        COLON
        TYPE-PARAMETERIZED "set" {
          LBRACKET
          TYPE-ATOM "string"
          RBRACKET
        }
        ATTR-LIST {
          ATTR "&log"
          ATTR "&optional"
        }
      }
      COMMENT-TRAILING "# A trailing comment here"
    }
    SEMI
  }
}
