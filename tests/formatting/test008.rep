FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_event"
  PARAMS {
    LPAREN
    PARAM "some_arg" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "some_name"
      DECL-INIT {
        ASSIGN "="
        CALL {
          IDENTIFIER "some_func"
          ARGS {
            LPAREN
            IDENTIFIER "arg_one"
            COMMA
            IDENTIFIER "arg_two"
            COMMA
            IDENTIFIER "arg_three"
            RPAREN
          }
        }
      }
      SEMI
    }
    RBRACE
  }
}
