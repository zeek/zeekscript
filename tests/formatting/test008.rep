FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_event"
  PARAMS {
    LPAREN
    PARAM "some_arg" {
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      IDENTIFIER "some_name"
      ASSIGN "="
      CALL {
        IDENTIFIER "some_func"
        ARGS {
          LPAREN
          IDENTIFIER "arg_one"
          COMMA
          IDENTIFIER "arg_two"
          COMMA
          IDENTIFIER "arg_three"
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
