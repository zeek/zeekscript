FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "test"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          EXPR-STMT {
            CALL {
              IDENTIFIER "Aaaaaa::aaa_aaaaa"
              ARGS {
                LPAREN
                CONSTANT "\"Aaaaaaaaaaaa::aaaaaaaa_aaaaaa_aaaaaaaaaa\""
                COMMA
                IDENTIFIER "Aaaaaaaaaa::AAA"
                COMMA
                CONSTANT "\"Aaaaaaaaaaaa::aaaaaa_aa_aaaaaaaaa_aaaaaaaa\""
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
