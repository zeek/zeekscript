FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    COMMENT-LEADING "# Create stream for our alternative, coalesced files.log-like log."
    EXPR-STMT {
      CALL {
        IDENTIFIER "Log::create_stream"
        ARGS {
          LPAREN
          IDENTIFIER "LOG"
          COMMA
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              FIELD-ASSIGN "columns" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "Info"
              }
              COMMA
              FIELD-ASSIGN "path" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "path"
              }
              COMMA
              FIELD-ASSIGN "policy" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "log_policy"
              }
              RBRACKET
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
