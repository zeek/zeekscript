FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "x"
      DECL-INIT {
        ASSIGN "="
        CALL {
          IDENTIFIER "copy"
          ARGS {
            LPAREN
            IDENTIFIER "some_val"
            RPAREN
          }
        }
      }
      SEMI
    }
    EXPR-STMT {
      UNARY-OP "++" {
        OP "++"
        IDENTIFIER "x"
      }
      SEMI
    }
    EXPR-STMT {
      UNARY-OP "--" {
        OP "--"
        IDENTIFIER "x"
      }
      SEMI
    }
    RBRACE
  }
}
