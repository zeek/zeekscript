FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_encrypted_data"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "is_orig" {
      COLON
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "some_record_vers" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "some_content_t" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "length" {
      COLON
      TYPE-ATOM "count"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      CONSTANT "\"some-group\""
    }
  }
  BODY {
    LBRACE
    RBRACE
  }
}
