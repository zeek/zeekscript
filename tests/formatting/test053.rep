FUNC-DECL "event" "some_encrypted_data" {
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    PARAM "is_orig" {
      TYPE-ATOM "bool"
    }
    PARAM "some_record_vers" {
      TYPE-ATOM "count"
    }
    PARAM "some_content_t" {
      TYPE-ATOM "count"
    }
    PARAM "length" {
      TYPE-ATOM "count"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      CONSTANT "\"some-group\""
    }
  }
  BODY {
    LBRACE
    RBRACE
  }
}
