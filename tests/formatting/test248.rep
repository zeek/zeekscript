GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "xxxxxxxxxxxxxxxxxxxx"
  DECL-TYPE {
    COLON
    TYPE-FUNC-RET "function" {
      PARAMS {
        LPAREN
        PARAM "xx" {
          COLON
          TYPE-ATOM "string"
        }
        COMMA
        PARAM "xxxxxxxxx" {
          COLON
          TYPE-PARAMETERIZED "set" {
            SUBSCRIPTS {
              LBRACKET
              TYPE-ATOM "subnet"
              RBRACKET
            }
          }
        }
        COMMA
        PARAM "xxxxxxxx" {
          COLON
          TYPE-ATOM "string"
        }
        RPAREN
      }
      COLON
      RETURNS {
        TYPE-PARAMETERIZED "set" {
          SUBSCRIPTS {
            LBRACKET
            TYPE-ATOM "subnet"
            RBRACKET
          }
        }
      }
    }
  }
  SEMI
}
