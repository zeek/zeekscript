FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "val" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-WITH-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "==" {
        IDENTIFIER "some_pattern"
        OP "=="
        IDENTIFIER "val"
      }
      RPAREN
      BODY {
        EXPR-STMT {
          BINARY-OP "=" {
            IDENTIFIER "result"
            OP "="
            CONSTANT "\"found\""
          }
          SEMI
        }
      }
      ELSE-BODY {
        KEYWORD "else"
        SP
        EXPR-STMT {
          BINARY-OP "=" {
            IDENTIFIER "result"
            OP "="
            CONSTANT "\"default\""
          }
          SEMI
        }
      }
    }
    RBRACE
  }
}
