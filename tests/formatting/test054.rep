GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_event_decl"
  DECL-TYPE {
    COLON
    TYPE-FUNC "event" {
      PARAMS {
        LPAREN
        PARAM "o" {
          COLON
          TYPE-ATOM "string"
        }
        COMMA
        PARAM "label" {
          COLON
          TYPE-ATOM "string"
        }
        COMMA
        PARAM "conf" {
          COLON
          TYPE-ATOM "score"
        }
        COMMA
        PARAM "sources" {
          COLON
          TYPE-PARAMETERIZED "set" {
            SUBSCRIPTS {
              LBRACKET
              TYPE-ATOM "string"
              RBRACKET
            }
          }
        }
        COMMA
        PARAM "caller" {
          COLON
          TYPE-ATOM "string"
        }
        RPAREN
      }
    }
  }
  SEMI
}
