FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "Log::write"
        ARGS {
          LPAREN
          IDENTIFIER "FTP_LOG"
          COMMA
          CALL {
            IDENTIFIER "FTPConnections"
            ARGS {
              LPAREN
              FIELD-ASSIGN "date" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "date"
              }
              COMMA
              FIELD-ASSIGN "orig_subnet" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "orig_subnet"
              }
              COMMA
              FIELD-ASSIGN "resp_subnet" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "resp_subnet"
              }
              COMMA
              FIELD-ASSIGN "uid" {
                DOLLAR
                ASSIGN "="
                FIELD-ACCESS {
                  IDENTIFIER "c"
                  DOLLAR
                  IDENTIFIER "uid"
                }
              }
              RPAREN
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
