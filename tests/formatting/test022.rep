FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    PARAM "si" {
      TYPE-ATOM "SomeInfo"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "&&" {
        BINARY-OP "&&" {
          BINARY-OP ">" {
            IDENTIFIER "coal_max_entries"
            OP ">"
            CONSTANT "0"
          }
          OP "&&"
          BINARY-OP ">=" {
            UNARY-OP "|...|" {
              OP "|"
              IDENTIFIER "coalesced_state"
              OP "|"
            }
            OP ">="
            IDENTIFIER "coal_max_entries"
          }
        }
        OP "&&"
        BINARY-OP "!in" {
          INDEX-LITERAL {
            LBRACKET
            IDENTIFIER "server_name"
            COMMA
            IDENTIFIER "server_subj"
            COMMA
            IDENTIFIER "server_issuer"
            COMMA
            IDENTIFIER "client_subj"
            COMMA
            IDENTIFIER "client_issuer"
            COMMA
            IDENTIFIER "ja3"
            RBRACKET
          }
          OP "!in"
          IDENTIFIER "coalesced_state"
        }
      }
      RPAREN
      BODY {
        RETURN
        SEMI
      }
    }
    RBRACE
  }
}
