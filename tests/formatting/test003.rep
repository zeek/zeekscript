FUNC-DECL "event" "some_handler" {
  PARAMS {
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    PARAM "is_orig" {
      TYPE-ATOM "bool"
    }
    PARAM "payload" {
      TYPE-ATOM "string"
    }
  }
  BODY {
    ADD {
      INDEX {
        FIELD-ACCESS {
          IDENTIFIER "c"
          IDENTIFIER "app"
        }
        SUBSCRIPTS {
          CONSTANT "\"test\""
        }
      }
      SEMI
    }
  }
  COMMENT-TRAILING "#@ NOT-TESTED"
}
