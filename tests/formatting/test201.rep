FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_rpc_handler"
  PARAMS {
    LPAREN
    PARAM "aa" {
      COLON
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "bbb" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "cccc" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "ddd" {
      COLON
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "eee_major" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "fff_minor" {
      COLON
      TYPE-ATOM "count"
    }
    RPAREN
  }
  BODY {
    LBRACE
    RBRACE
  }
  COMMENT-TRAILING "#@ NOT-TESTED"
}
