FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "ssl_extension"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "is_client" {
      COLON
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "code" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "val" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      ASSIGN "="
      CONSTANT "\"doh-generic\""
    }
  }
  BODY {
    LBRACE
    RBRACE
  }
}
