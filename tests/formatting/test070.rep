RETURN {
  KEYWORD "return"
  BINARY-OP "&&" {
    BINARY-OP "in" {
      IDENTIFIER "some_very_long_variable_name"
      OP "in"
      IDENTIFIER "some_other_very_long_variable_name"
    }
    OP "&&"
    BINARY-OP "in" {
      IDENTIFIER "another_thing"
      OP "in"
      IDENTIFIER "yet_another_thing"
    }
  }
  SEMI
}
