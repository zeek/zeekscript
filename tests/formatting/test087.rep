GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "x"
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      ARGS {
        LPAREN
        BINARY-OP "=" {
          INDEX-LITERAL {
            LBRACKET
            CONSTANT "1"
            RBRACKET
          }
          OP "="
          CONSTANT "\"one\""
        }
        RPAREN
      }
    }
  }
  SEMI
}
