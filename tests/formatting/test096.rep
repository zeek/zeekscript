FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "some_handler"
        ARGS {
          LPAREN
          IDENTIFIER "opt_id"
          COMMA
          LAMBDA {
            KEYWORD "function"
            SP
            CAPTURES {
              LBRACKET
              IDENTIFIER "evt_grp"
              RBRACKET
            }
            PARAMS {
              LPAREN
              PARAM "id" {
                COLON
                TYPE-ATOM "string"
              }
              COMMA
              PARAM "val" {
                COLON
                TYPE-ATOM "bool"
              }
              RPAREN
            }
            COLON
            RETURNS {
              TYPE-ATOM "bool"
            }
            BODY {
              LBRACE
              RETURN {
                KEYWORD "return"
                SP
                IDENTIFIER "val"
                SEMI
              }
              RBRACE
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
