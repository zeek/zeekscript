FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      CALL {
        IDENTIFIER "some_condition"
        ARGS {
          LPAREN
          RPAREN
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          BLANK
          LOCAL-DECL {
            KEYWORD "local"
            SP
            IDENTIFIER "published"
            DECL-INIT {
              ASSIGN "="
              CALL {
                IDENTIFIER "Some::long_func_name"
                ARGS {
                  LPAREN
                  IDENTIFIER "proxy_pool"
                  COMMA
                  CALL {
                    IDENTIFIER "cat"
                    ARGS {
                      LPAREN
                      FIELD-ACCESS {
                        FIELD-ACCESS {
                          IDENTIFIER "c"
                          DOLLAR
                          IDENTIFIER "id"
                        }
                        DOLLAR
                        IDENTIFIER "orig_h"
                      }
                      COMMA
                      IDENTIFIER "fqdn"
                      RPAREN
                    }
                  }
                  COMMA
                  IDENTIFIER "SomeModule::some_handler"
                  COMMA
                  FIELD-ACCESS {
                    FIELD-ACCESS {
                      IDENTIFIER "c"
                      DOLLAR
                      IDENTIFIER "id"
                    }
                    DOLLAR
                    IDENTIFIER "orig_h"
                  }
                  COMMA
                  FIELD-ACCESS {
                    IDENTIFIER "c"
                    DOLLAR
                    IDENTIFIER "uid"
                  }
                  COMMA
                  IDENTIFIER "fqdn"
                  COMMA
                  FIELD-ACCESS {
                    IDENTIFIER "conn"
                    DOLLAR
                    IDENTIFIER "orig_bytes"
                  }
                  RPAREN
                }
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
