FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      CALL {
        IDENTIFIER "some_condition"
        ARGS {
          LPAREN
          RPAREN
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          BLANK
          LOCAL-DECL {
            KEYWORD "local"
            IDENTIFIER "published"
            ASSIGN "="
            CALL {
              IDENTIFIER "Some::long_func_name"
              ARGS {
                LPAREN
                IDENTIFIER "proxy_pool"
                COMMA
                CALL {
                  IDENTIFIER "cat"
                  ARGS {
                    LPAREN
                    FIELD-ACCESS {
                      FIELD-ACCESS {
                        IDENTIFIER "c"
                        IDENTIFIER "id"
                      }
                      IDENTIFIER "orig_h"
                    }
                    COMMA
                    IDENTIFIER "fqdn"
                    RPAREN
                  }
                }
                COMMA
                IDENTIFIER "SomeModule::some_handler"
                COMMA
                FIELD-ACCESS {
                  FIELD-ACCESS {
                    IDENTIFIER "c"
                    IDENTIFIER "id"
                  }
                  IDENTIFIER "orig_h"
                }
                COMMA
                FIELD-ACCESS {
                  IDENTIFIER "c"
                  IDENTIFIER "uid"
                }
                COMMA
                IDENTIFIER "fqdn"
                COMMA
                FIELD-ACCESS {
                  IDENTIFIER "conn"
                  IDENTIFIER "orig_bytes"
                }
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
