FUNC-DECL "function" "some_func" {
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      IDENTIFIER "test"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          BLANK
          LOCAL-DECL "local" "some_val" {
            ASSIGN "="
            CALL {
              IDENTIFIER "some_long_func_name"
              ARGS {
                LPAREN
                INDEX {
                  IDENTIFIER "result_chain"
                  SUBSCRIPTS {
                    LBRACKET
                    CONSTANT "1"
                    RBRACKET
                  }
                }
                COMMA
                CONSTANT "4"
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
          COMMENT-TRAILING "# HASH"
        }
      }
    }
    RBRACE
  }
}
