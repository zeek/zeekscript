FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "test"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          BLANK
          LOCAL-DECL {
            KEYWORD "local"
            SP
            IDENTIFIER "some_val"
            DECL-INIT {
              ASSIGN "="
              CALL {
                IDENTIFIER "some_long_func_name"
                ARGS {
                  LPAREN
                  INDEX {
                    IDENTIFIER "result_chain"
                    SUBSCRIPTS {
                      LBRACKET
                      CONSTANT "1"
                      RBRACKET
                    }
                  }
                  COMMA
                  CONSTANT "4"
                  RPAREN
                }
              }
            }
            SEMI
          }
          COMMENT-TRAILING "# HASH"
          RBRACE
        }
      }
    }
    RBRACE
  }
}
