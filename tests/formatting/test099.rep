FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "info"
      ASSIGN "="
      CALL {
        IDENTIFIER "SomeModule::SomeRecord"
        ARGS {
          LPAREN
          FIELD-ASSIGN "field1" {
            DOLLAR
            ASSIGN "="
            IDENTIFIER "some_very_long_value"
          }
          COMMA
          FIELD-ASSIGN "field2" {
            DOLLAR
            ASSIGN "="
            IDENTIFIER "another_long_value"
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
