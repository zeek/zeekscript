EXPR-STMT {
  CALL {
    IDENTIFIER "NOTICE"
    ARGS {
      LPAREN
      INDEX-LITERAL {
        LBRACKET
        FIELD-ASSIGN "msg" {
          DOLLAR
          ASSIGN "="
          CALL {
            IDENTIFIER "fmt"
            ARGS {
              LPAREN
              CONSTANT "\"Value %s was more than %dMB for item %s\""
              COMMA
              IDENTIFIER "some_var"
              COMMA
              BINARY-OP "/" {
                IDENTIFIER "some_long_variable_name"
                OP "/"
                CONSTANT "1000 / 1000"
              }
              COMMA
              IDENTIFIER "bucket"
              RPAREN
            }
          }
        }
        RBRACKET
      }
      RPAREN
    }
  }
  SEMI
}
