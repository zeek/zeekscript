FUNC-DECL "event" "some_event" {
  PARAMS {
    LPAREN
    PARAM "some_arg" {
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      CONSTANT "T"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          BLANK
          IF {
            KEYWORD "if"
            LPAREN
            CONSTANT "T"
            RPAREN
            BODY {
              BLOCK {
                LBRACE
                BLANK
                LOCAL-DECL "local" "some_long_name" {
                  ASSIGN "="
                  CALL {
                    IDENTIFIER "SomeModule::some_function"
                    ARGS {
                      LPAREN
                      IDENTIFIER "some_really_long_argument"
                      RPAREN
                    }
                  }
                  SEMI
                }
                RBRACE
              }
            }
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
