FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_event"
  PARAMS {
    LPAREN
    PARAM "some_arg" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      CONSTANT "T"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          BLANK
          IF-NO-ELSE {
            KEYWORD "if"
            SP
            LPAREN
            CONSTANT "T"
            RPAREN
            BODY {
              BLOCK {
                LBRACE
                BLANK
                LOCAL-DECL {
                  KEYWORD "local"
                  SP
                  IDENTIFIER "some_long_name"
                  ASSIGN "="
                  CALL {
                    IDENTIFIER "SomeModule::some_function"
                    ARGS {
                      LPAREN
                      IDENTIFIER "some_really_long_argument"
                      RPAREN
                    }
                  }
                  SEMI
                }
                RBRACE
              }
            }
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
