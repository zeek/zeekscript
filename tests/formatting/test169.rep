FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "count"
  }
  BODY {
    LBRACE
    RETURN {
      KEYWORD "return"
      SP
      CONSTANT "42"
      SEMI
    }
    COMMENT-TRAILING "# the answer"
    RBRACE
  }
}
