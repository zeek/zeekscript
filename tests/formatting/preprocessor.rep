FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "SomeModule::some_esp_message"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "is_orig" {
      COLON
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "msg" {
      COLON
      TYPE-ATOM "SomeModule::SomeEspMsg"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      ASSIGN "="
      IDENTIFIER "MyPkg_SomeEvtGroup"
    }
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "shuntit"
        ARGS {
          LPAREN
          IDENTIFIER "c"
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
PREPROC "@endif"
BLANK
