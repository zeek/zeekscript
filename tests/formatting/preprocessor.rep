FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PREPROC-COND "@if" "FOO" {
      LPAREN
      RPAREN
    }
    PRINT {
      KEYWORD "print"
      SP
      CONSTANT "1"
      SEMI
    }
    PREPROC "@endif"
    RBRACE
  }
}
