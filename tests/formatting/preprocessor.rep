COMMENT-LEADING "# Preprocessor directives: @if/@else/@endif, @ifdef/@ifndef, @load, nesting inside function bodies, with trailing comments and annotations."
BLANK
COMMENT-LEADING "# Some comment."
COMMENT-LEADING "#@ BEGIN-SKIP-TESTING"
PREPROC-COND "@if" "some_func(\"/some/path\") > 0" {
  LPAREN
  RPAREN
}
PREPROC "@load" "/some/path"
PREPROC "@else"
PREPROC "@load" "packages/some-pkg"
PREPROC "@endif"
COMMENT-LEADING "#@ END-SKIP-TESTING"
BLANK
PREPROC-COND "@ifdef" "SOME_FEATURE" {
  LPAREN
  RPAREN
}
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      SP
      IDENTIFIER "some_var"
      SEMI
    }
    RBRACE
  }
}
BLANK
COMMENT-LEADING "# Fallback path below."
PREPROC "@else"
BLANK
