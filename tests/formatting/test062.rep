FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    FOR {
      KEYWORD "for"
      SP
      LPAREN
      VARS {
        IDENTIFIER "idx"
      }
      KEYWORD "in"
      SP
      ITERABLE {
        FIELD-ACCESS {
          IDENTIFIER "result"
          DOLLAR
          IDENTIFIER "matches"
        }
      }
      RPAREN
      BODY {
        FOR {
          KEYWORD "for"
          SP
          LPAREN
          VARS {
            IDENTIFIER "conn_idx"
          }
          KEYWORD "in"
          SP
          ITERABLE {
            FIELD-ACCESS {
              IDENTIFIER "result"
              DOLLAR
              IDENTIFIER "some_uids_with_a_very_long_field_name_that_forces_wrapping"
            }
          }
          RPAREN
          BODY {
            LOCAL-DECL {
              KEYWORD "local"
              SP
              IDENTIFIER "x"
              ASSIGN "="
              CONSTANT "1"
              SEMI
            }
          }
        }
      }
    }
    RBRACE
  }
}
