PREPROC-COND "@ifdef" "SomeFeature" {
  LPAREN
  RPAREN
}
BLANK
MODULE "SomeMod" {
  KEYWORD "module"
  SP
  IDENTIFIER "SomeMod"
  SEMI
}
BLANK
GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "some_var"
  ASSIGN "="
  CONSTANT "\"some-value\""
  SEMI
}
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      SP
      IDENTIFIER "some_var"
      SEMI
    }
    RBRACE
  }
}
PREPROC "@endif"
