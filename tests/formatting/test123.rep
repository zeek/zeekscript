PREPROC "@ifdef" "SomeFeature"
BLANK
MODULE "SomeMod"
BLANK
GLOBAL-DECL {
  KEYWORD "const"
  IDENTIFIER "some_var"
  ASSIGN "="
  CONSTANT "\"some-value\""
  SEMI
}
BLANK
FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      IDENTIFIER "some_var"
      SEMI
    }
    RBRACE
  }
}
PREPROC "@endif"
