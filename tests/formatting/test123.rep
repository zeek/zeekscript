PREPROC "@ifdef" "SomeFeature"
BLANK
MODULE "SomeMod"
BLANK
GLOBAL-DECL "const" "some_var" {
  ASSIGN "="
  CONSTANT "\"some-value\""
  SEMI
}
BLANK
FUNC-DECL "event" "zeek_init" {
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      IDENTIFIER "some_var"
      SEMI
    }
    RBRACE
  }
}
PREPROC "@endif"
