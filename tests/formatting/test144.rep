GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "ss"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "set" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "addr"
        RBRACKET
      }
    }
  }
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "set"
      LPAREN
      CONSTANT "1.2.3.4"
      COMMA
      CONSTANT "5.6.7.8"
      RPAREN
    }
  }
  SEMI
}
