FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "set_groups"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    SWITCH {
      KEYWORD "switch"
      SP
      IDENTIFIER "foo"
      LBRACE
      COMMENT-LEADING "#@ BEGIN-NOT-TESTED"
      CASE {
        KEYWORD "case"
        SP
        VALUES {
          CONSTANT "4"
        }
        COLON
        BODY {
          EXPR-STMT {
            BINARY-OP "=" {
              FIELD-ACCESS {
                IDENTIFIER "rec"
                DOLLAR
                IDENTIFIER "field_a"
              }
              OP "="
              IDENTIFIER "val_a"
            }
            SEMI
          }
          EXPR-STMT {
            BINARY-OP "=" {
              FIELD-ACCESS {
                IDENTIFIER "rec"
                DOLLAR
                IDENTIFIER "field_b"
              }
              OP "="
              IDENTIFIER "val_b"
            }
            SEMI
          }
          KEYWORD "break"
          SEMI
        }
      }
      COMMENT-LEADING "#@ END-NOT-TESTED"
      RBRACE
    }
    RBRACE
  }
}
