FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "Some::create_stream"
        ARGS {
          LPAREN
          IDENTIFIER "SOME::LOG"
          COMMA
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              FIELD-ASSIGN "columns" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "Info"
              }
              COMMA
              FIELD-ASSIGN "path" {
                DOLLAR
                ASSIGN "="
                CONSTANT "\"some_path\""
              }
              COMMA
              FIELD-ASSIGN "policy" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "log_policy"
              }
              RBRACKET
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
