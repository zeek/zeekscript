FUNC-DECL "event" "zeek_init" {
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "Some::create_stream"
        ARGS {
          LPAREN
          IDENTIFIER "SOME::LOG"
          COMMA
          INDEX-LITERAL {
            LBRACKET
            FIELD-ASSIGN "columns" {
              IDENTIFIER "Info"
            }
            COMMA
            FIELD-ASSIGN "path" {
              CONSTANT "\"some_path\""
            }
            COMMA
            FIELD-ASSIGN "policy" {
              IDENTIFIER "log_policy"
            }
            RBRACKET
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
