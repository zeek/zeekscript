FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_generic_packet_threshold_crossed"
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "threshold" {
      TYPE-ATOM "count"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      IDENTIFIER "MyPkg_SomeUnknownprotos_EvtGroup"
    }
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      IDENTIFIER "c"
      SEMI
    }
    RBRACE
  }
}
