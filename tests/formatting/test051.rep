FUNC-DECL "event" "some_generic_packet_threshold_crossed" {
  PARAMS {
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    PARAM "threshold" {
      TYPE-ATOM "count"
    }
  }
  ATTR-LIST {
    ATTR "&group" {
      IDENTIFIER "MyPkg_SomeUnknownprotos_EvtGroup"
    }
  }
  BODY {
    PRINT {
      IDENTIFIER "c"
      SEMI
    }
  }
}
