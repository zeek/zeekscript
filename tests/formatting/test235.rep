FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "aaa_bbbbbbb"
  PARAMS {
    LPAREN
    PARAM "a" {
      COLON
      TYPE-ATOM "aaaaaaaaaa"
    }
    COMMA
    PARAM "bbb_ccc" {
      COLON
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "dddd" {
      COLON
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "eeeee" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "||" {
        HAS-FIELD {
          BINARY-OP "||" {
            PAREN {
              LPAREN
              BINARY-OP "&&" {
                BINARY-OP "==" {
                  FIELD-ACCESS {
                    FIELD-ACCESS {
                      IDENTIFIER "a"
                      DOLLAR
                      IDENTIFIER "bbbb"
                    }
                    DOLLAR
                    IDENTIFIER "aaaaaa_bbbbbbbbb_cccccc_ddddd1"
                  }
                  OP "=="
                  CONSTANT "2"
                }
                OP "&&"
                BINARY-OP "==" {
                  FIELD-ACCESS {
                    FIELD-ACCESS {
                      IDENTIFIER "a"
                      DOLLAR
                      IDENTIFIER "bbbb"
                    }
                    DOLLAR
                    IDENTIFIER "aaaaaa_bbbbbbbbb_cccccc_ddddd2"
                  }
                  OP "=="
                  CONSTANT "2"
                }
              }
              RPAREN
            }
            OP "||"
            NEGATION {
              OP "!"
              FIELD-ACCESS {
                IDENTIFIER "a"
                DOLLAR
                IDENTIFIER "bbbb"
              }
            }
          }
          OP "?$"
          IDENTIFIER "ffffff"
        }
        OP "||"
        BINARY-OP "!=" {
          FIELD-ACCESS {
            FIELD-ACCESS {
              IDENTIFIER "a"
              DOLLAR
              IDENTIFIER "bbbb"
            }
            DOLLAR
            IDENTIFIER "ffffff"
          }
          OP "!="
          CONSTANT "\"AAAA\""
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          RETURN-VOID {
            KEYWORD "return"
            SP
            SEMI
          }
          COMMENT-TRAILING "#@ NOT-TESTED"
          RBRACE
        }
      }
    }
    RBRACE
  }
}
