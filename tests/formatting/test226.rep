FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    COMMENT-LEADING "# A comment."
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      HAS-FIELD {
        IDENTIFIER "fi"
        OP "?$"
        IDENTIFIER "md5"
      }
      RPAREN
      BODY {
        SAME-LINE
        EXPR-STMT {
          BINARY-OP "=" {
            FIELD-ACCESS {
              IDENTIFIER "fi_red"
              DOLLAR
              IDENTIFIER "md5"
            }
            OP "="
            FIELD-ACCESS {
              IDENTIFIER "fi"
              DOLLAR
              IDENTIFIER "md5"
            }
          }
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      HAS-FIELD {
        IDENTIFIER "fi"
        OP "?$"
        IDENTIFIER "sha1"
      }
      RPAREN
      BODY {
        SAME-LINE
        EXPR-STMT {
          BINARY-OP "=" {
            FIELD-ACCESS {
              IDENTIFIER "fi_red"
              DOLLAR
              IDENTIFIER "sha1"
            }
            OP "="
            FIELD-ACCESS {
              IDENTIFIER "fi"
              DOLLAR
              IDENTIFIER "sha1"
            }
          }
          SEMI
        }
      }
    }
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      HAS-FIELD {
        IDENTIFIER "fi"
        OP "?$"
        IDENTIFIER "sha256"
      }
      RPAREN
      BODY {
        SAME-LINE
        EXPR-STMT {
          BINARY-OP "=" {
            FIELD-ACCESS {
              IDENTIFIER "fi_red"
              DOLLAR
              IDENTIFIER "sha256"
            }
            OP "="
            FIELD-ACCESS {
              IDENTIFIER "fi"
              DOLLAR
              IDENTIFIER "sha256"
            }
          }
          SEMI
        }
      }
    }
    RBRACE
  }
}
