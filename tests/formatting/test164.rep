FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "x"
      DECL-INIT {
        ASSIGN "="
        CONSTANT "1"
      }
      SEMI
    }
    COMMENT-TRAILING "# init"
    RBRACE
  }
}
