GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "ftp_connections_cache"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "set" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "string"
        COMMA
        TYPE-ATOM "string"
        COMMA
        TYPE-ATOM "string"
        RBRACKET
      }
    }
  }
  ATTR-LIST {
    ATTR "&read_expire" {
      ASSIGN "="
      IDENTIFIER "cache_interval"
    }
  }
  SEMI
}
