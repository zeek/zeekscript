EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "const"
    SP
    IDENTIFIER "default_analyzer"
    DECL-TYPE {
      COLON
      TYPE-ATOM "PacketAnalyzer::Tag"
    }
    DECL-INIT {
      ASSIGN "="
      IDENTIFIER "PacketAnalyzer::ANALYZER_IP"
    }
    ATTR-LIST {
      ATTR "&redef"
    }
    SEMI
  }
  RBRACE
}
