FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "SomeModule::setup_stream"
        ARGS {
          LPAREN
          IDENTIFIER "SOME_STREAM_LOG"
          COMMA
          INDEX-LITERAL {
            LBRACKET
            FIELD-ASSIGN "columns" {
              IDENTIFIER "SomeStreamInfo"
            }
            COMMA
            FIELD-ASSIGN "path" {
              CONSTANT "\"some_long_module_stream_path\""
            }
            COMMA
            FIELD-ASSIGN "policy" {
              IDENTIFIER "some_stream_log_policy"
            }
            RBRACKET
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
