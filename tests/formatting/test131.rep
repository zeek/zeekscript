FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "SomeModule::setup_stream"
        ARGS {
          LPAREN
          IDENTIFIER "SOME_STREAM_LOG"
          COMMA
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              FIELD-ASSIGN "columns" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "SomeStreamInfo"
              }
              COMMA
              FIELD-ASSIGN "path" {
                DOLLAR
                ASSIGN "="
                CONSTANT "\"some_long_module_stream_path\""
              }
              COMMA
              FIELD-ASSIGN "policy" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "some_stream_log_policy"
              }
              RBRACKET
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
