GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_tracking_var"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "count"
        COMMA
        TYPE-ATOM "string"
        RBRACKET
      }
      KEYWORD "of"
      SP
      TYPE-ATOM "TrackingRec"
    }
  }
  ATTR-LIST {
    ATTR "&default_insert" {
      ASSIGN "="
      CALL {
        IDENTIFIER "TrackingRec"
        ARGS {
          LPAREN
          FIELD-ASSIGN "field" {
            DOLLAR
            ASSIGN "="
            IDENTIFIER "val"
          }
          RPAREN
        }
      }
    }
    ATTR "&create_expire" {
      ASSIGN "="
      INTERVAL "10" "sec"
    }
    ATTR "&redef"
  }
  SEMI
}
