FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "message"
      DECL-INIT {
        ASSIGN "="
        CALL {
          IDENTIFIER "fmt"
          ARGS {
            LPAREN
            CONSTANT "\"Meterpreter detected with reason=CERTIFICATE_DETECTED, protocol=HTTPS, os=ANY\""
            RPAREN
          }
        }
      }
      SEMI
    }
    RBRACE
  }
}
