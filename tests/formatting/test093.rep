LOCAL-DECL "local" "x" {
  ASSIGN "="
  INDEX-LITERAL {
    LBRACKET
    FIELD-ASSIGN "msg" {
      CALL {
        IDENTIFIER "fmt"
        ARGS {
          LPAREN
          CONSTANT "\"Host uses protocol version %s which is lower than the safe minimum %s\""
          COMMA
          IDENTIFIER "some_string"
          COMMA
          IDENTIFIER "other_string_a"
          RPAREN
        }
      }
    }
    RBRACKET
  }
  SEMI
}
