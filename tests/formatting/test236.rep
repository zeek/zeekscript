FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "test1"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          PREPROC-COND "@ifdef" "bar" {
            LPAREN
            RPAREN
          }
          RETURN-VOID {
            KEYWORD "return"
            SP
            SEMI
          }
          COMMENT-TRAILING "#@ NOT-TESTED"
          PREPROC "@endif"
          RBRACE
        }
      }
    }
    RBRACE
  }
}
