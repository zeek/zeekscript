COMMENT-LEADING "# Global with wrapped attrs inside export block."
EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "global"
    SP
    IDENTIFIER "recently_validated_certs"
    DECL-TYPE {
      COLON
      TYPE-PARAMETERIZED "table" {
        SUBSCRIPTS {
          LBRACKET
          TYPE-ATOM "string"
          RBRACKET
        }
        KEYWORD "of"
        SP
        TYPE-ATOM "X509::Result"
      }
    }
    ATTR-LIST {
      ATTR "&read_expire" {
        ASSIGN "="
        INTERVAL "5" "mins"
      }
      ATTR "&redef"
    }
    SEMI
  }
  RBRACE
}
