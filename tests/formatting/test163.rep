FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    WHILE {
      KEYWORD "while"
      SP
      LPAREN
      IDENTIFIER "some_flag"
      RPAREN
      COMMENT-TRAILING "# keep going"
      BODY {
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "1"
          SEMI
        }
      }
    }
    RBRACE
  }
}
