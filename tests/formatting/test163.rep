FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "a" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "b" {
      COLON
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "rec" {
      COLON
      TYPE-ATOM "SomeRec"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "in" {
        IDENTIFIER "rec"
        OP "in"
        IDENTIFIER "did_check"
      }
      RPAREN
      COMMENT-TRAILING "#@ BEGIN-SKIP-TESTING"
      BODY {
        RETURN {
          KEYWORD "return"
          SEMI
        }
      }
    }
    RBRACE
  }
}
