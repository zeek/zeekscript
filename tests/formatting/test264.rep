FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "NOTICE"
        ARGS {
          LPAREN
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              FIELD-ASSIGN "aaa" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "Xxxxxxxxx::XXXX"
              }
              COMMA
              FIELD-ASSIGN "bbb" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "c"
              }
              COMMA
              FIELD-ASSIGN "ccc" {
                DOLLAR
                ASSIGN "="
                CONSTANT "\"Potential Responder/Pretender MitM HTTP server headers detected. Refer https://attack.mitre.org/software/S0174/\""
              }
              RBRACKET
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
