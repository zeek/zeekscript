FUNC-DECL-RET {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "SomeModule::SomeType"
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BOOL-CHAIN "&&" {
        IDENTIFIER "some_condition"
        OP "&&"
        IDENTIFIER "some_other_condition"
      }
      RPAREN
      BODY {
        EXPR-STMT {
          BINARY-OP "=" {
            INDEX {
              IDENTIFIER "some_long_variable_name"
              SUBSCRIPTS {
                LBRACKET
                IDENTIFIER "some_id"
                RBRACKET
              }
            }
            OP "="
            CALL {
              IDENTIFIER "SomeModule::SomeType"
              ARGS {
                LPAREN
                FIELD-ASSIGN "aa" {
                  DOLLAR
                  ASSIGN "="
                  FIELD-ACCESS {
                    IDENTIFIER "result"
                    DOLLAR
                    IDENTIFIER "aa"
                  }
                }
                COMMA
                FIELD-ASSIGN "bb_string" {
                  DOLLAR
                  ASSIGN "="
                  FIELD-ACCESS {
                    IDENTIFIER "result"
                    DOLLAR
                    IDENTIFIER "bb_string"
                  }
                }
                RPAREN
              }
            }
          }
          SEMI
        }
      }
    }
    RBRACE
  }
}
