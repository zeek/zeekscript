FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "?$" {
        BINARY-OP "||" {
          BINARY-OP "||" {
            BINARY-OP "?$" {
              UNARY-OP "!" {
                OP "!"
                IDENTIFIER "aa"
              }
              OP "?$"
              IDENTIFIER "bb_chain"
            }
            OP "||"
            BINARY-OP "==" {
              UNARY-OP "|...|" {
                OP "|"
                FIELD-ACCESS {
                  IDENTIFIER "aa"
                  DOLLAR
                  IDENTIFIER "bb_chain"
                }
                OP "|"
              }
              OP "=="
              CONSTANT "0"
            }
          }
          OP "||"
          UNARY-OP "!" {
            OP "!"
            INDEX {
              FIELD-ACCESS {
                IDENTIFIER "aa"
                DOLLAR
                IDENTIFIER "bb_chain"
              }
              SUBSCRIPTS {
                LBRACKET
                CONSTANT "0"
                RBRACKET
              }
            }
          }
        }
        OP "?$"
        IDENTIFIER "cc"
      }
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          IDENTIFIER "dd"
          SEMI
        }
      }
    }
    RBRACE
  }
}
