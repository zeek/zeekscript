FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      HAS-FIELD {
        BOOL-CHAIN "||" {
          HAS-FIELD {
            NEGATION {
              OP "!"
              IDENTIFIER "aa"
            }
            OP "?$"
            IDENTIFIER "bb_chain"
          }
          OP "||"
          BINARY-OP "==" {
            CARDINALITY {
              OP "|"
              FIELD-ACCESS {
                IDENTIFIER "aa"
                DOLLAR
                IDENTIFIER "bb_chain"
              }
              OP "|"
            }
            OP "=="
            CONSTANT "0"
          }
          OP "||"
          NEGATION {
            OP "!"
            INDEX {
              FIELD-ACCESS {
                IDENTIFIER "aa"
                DOLLAR
                IDENTIFIER "bb_chain"
              }
              SUBSCRIPTS {
                LBRACKET
                CONSTANT "0"
                RBRACKET
              }
            }
          }
        }
        OP "?$"
        IDENTIFIER "cc"
      }
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          IDENTIFIER "dd"
          SEMI
        }
      }
    }
    RBRACE
  }
}
