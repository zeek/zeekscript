FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      KEYWORD-EXPR "hook" {
        KEYWORD "hook"
        SP
        CALL {
          IDENTIFIER "my_hook"
          ARGS {
            LPAREN
            IDENTIFIER "x"
            COMMA
            IDENTIFIER "y"
            RPAREN
          }
        }
      }
      SEMI
    }
    BLANK
    WHEN {
      KEYWORD "when"
      SP
      LPAREN
      CALL {
        IDENTIFIER "some_cond"
        ARGS {
          LPAREN
          RPAREN
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          PRINT {
            KEYWORD "print"
            SP
            CONSTANT "\"yes\""
            SEMI
          }
          RBRACE
        }
      }
    }
    BLANK
    WHEN-TIMEOUT {
      KEYWORD "when"
      SP
      LPAREN
      WHEN-LOCAL "result" {
        CALL {
          IDENTIFIER "do_lookup"
          ARGS {
            LPAREN
            IDENTIFIER "host"
            RPAREN
          }
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          PRINT {
            KEYWORD "print"
            SP
            IDENTIFIER "result"
            SEMI
          }
          RBRACE
        }
      }
      KEYWORD "timeout"
      SP
      TIMEOUT {
        INTERVAL "10" "secs"
        LBRACE
        BODY {
          PRINT {
            KEYWORD "print"
            SP
            CONSTANT "\"timeout\""
            SEMI
          }
        }
        RBRACE
      }
    }
    RBRACE
  }
}
