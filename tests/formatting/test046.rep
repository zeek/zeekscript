EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  TYPE-DECL "AnomalyTypes" {
    KEYWORD "type"
    SP
    IDENTIFIER "AnomalyTypes"
    COLON
    SP
    TYPE-ENUM {
      KEYWORD "enum"
      SP
      LBRACE
      ENUM-VALUE "ANOMALY"
      COMMA
      ENUM-VALUE "NEW_ENTITY"
      COMMA
      ENUM-VALUE "NEW_ITEM"
      COMMA
      ENUM-VALUE "NEW_ENTITY_NEW_ITEM"
      COMMA
      ENUM-VALUE "NEW_ENTITY_ITEM_PAIR"
      COMMA
      ENUM-VALUE "UNKNOWN"
      RBRACE
    }
    SEMI
  }
  RBRACE
}
