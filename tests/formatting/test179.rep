EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  REDEF-ENUM "Log::ID" {
    KEYWORD "redef"
    SP
    KEYWORD "enum"
    SP
    IDENTIFIER "Log::ID"
    ASSIGN "+="
    LBRACE
    ENUM-VALUE "LOG"
    RBRACE
    SEMI
  }
  RBRACE
}
BLANK
TYPEDECL-RECORD "CertInfo" {
  KEYWORD "type"
  SP
  IDENTIFIER "CertInfo"
  COLON
  SP
  TYPE-RECORD {
    KEYWORD "record"
    SP
    LBRACE
    FIELD "cn" {
      COLON
      TYPE-ATOM "string"
      ATTR-LIST {
        ATTR "&log"
        ATTR "&optional"
      }
      SEMI
    }
    FIELD "sans" {
      COLON
      TYPE-PARAMETERIZED "set" {
        SUBSCRIPTS {
          LBRACKET
          TYPE-ATOM "string"
          RBRACKET
        }
      }
      ATTR-LIST {
        ATTR "&log"
        ATTR "&optional"
      }
      SEMI
    }
    RBRACE
  }
  SEMI
}
