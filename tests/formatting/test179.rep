GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "xs"
  DECL-TYPE {
    COLON
    TYPE-OF "vector" {
      KEYWORD "of"
      SP
      TYPE-ATOM "double"
    }
  }
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "vector"
      ARGS {
        LPAREN
        CONSTANT "0.01"
        COMMA
        CONSTANT "0.02"
        COMMA
        COMMENT-TRAILING "# note"
        CONSTANT "0.03"
        RPAREN
      }
    }
  }
  SEMI
}
