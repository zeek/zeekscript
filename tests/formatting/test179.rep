GLOBAL-DECL {
  KEYWORD "const"
  IDENTIFIER "xs"
  COLON
  TYPE-PARAMETERIZED "vector" {
    KEYWORD "of"
    TYPE-ATOM "double"
  }
  ASSIGN "="
  CONSTRUCTOR {
    KEYWORD "vector"
    LPAREN
    CONSTANT "0.01"
    COMMA
    CONSTANT "0.02"
    COMMA
    COMMENT-TRAILING "# note"
    CONSTANT "0.03"
    RPAREN
  }
  SEMI
}
