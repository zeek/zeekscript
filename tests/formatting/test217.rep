FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "&&" {
        HAS-FIELD {
          BINARY-OP "&&" {
            BINARY-OP "&&" {
              IDENTIFIER "ssl_cache_intermediate_ca"
              OP "&&"
              BINARY-OP "==" {
                FIELD-ACCESS {
                  IDENTIFIER "result"
                  DOLLAR
                  IDENTIFIER "result_string"
                }
                OP "=="
                CONSTANT "\"ok\""
              }
            }
            OP "&&"
            IDENTIFIER "result"
          }
          OP "?$"
          IDENTIFIER "chain_certs"
        }
        OP "&&"
        BINARY-OP ">" {
          CARDINALITY {
            OP "|"
            FIELD-ACCESS {
              IDENTIFIER "result"
              DOLLAR
              IDENTIFIER "chain_certs"
            }
            OP "|"
          }
          OP ">"
          CONSTANT "2"
        }
      }
      RPAREN
      BODY {
        EXPR-STMT {
          CALL {
            IDENTIFIER "bar"
            ARGS {
              LPAREN
              RPAREN
            }
          }
          SEMI
        }
      }
    }
    RBRACE
  }
}
