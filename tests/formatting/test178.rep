GLOBAL-DECL "const" "xs" {
  COLON
  TYPE-PARAMETERIZED "vector" {
    KEYWORD "of"
    TYPE-ATOM "double"
  }
  ASSIGN "="
  CONSTRUCTOR "vector" {
    LPAREN
    CONSTANT "0.01"
    COMMA
    CONSTANT "0.02"
    COMMA
    COMMENT-TRAILING "# a note"
    CONSTANT "0.03"
    COMMA
    CONSTANT "0.04"
    RPAREN
  }
  SEMI
}
