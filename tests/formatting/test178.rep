FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "&&" {
        HAS-FIELD {
          FIELD-ACCESS {
            IDENTIFIER "x"
            DOLLAR
            IDENTIFIER "y"
          }
          OP "?$"
          IDENTIFIER "z"
        }
        OP "&&"
        BINARY-OP ">" {
          CARDINALITY {
            OP "|"
            BINARY-OP "&" {
              FIELD-ACCESS {
                FIELD-ACCESS {
                  IDENTIFIER "x"
                  DOLLAR
                  IDENTIFIER "y"
                }
                DOLLAR
                IDENTIFIER "z"
              }
              OP "&"
              IDENTIFIER "s"
            }
            OP "|"
          }
          OP ">"
          CONSTANT "0"
        }
      }
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "T"
          SEMI
        }
      }
    }
    COMMENT-TRAILING "#@ NOT-TESTED"
    RBRACE
  }
}
