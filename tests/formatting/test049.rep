FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "SomeModule::some_raised_evt"
  PARAMS {
    LPAREN
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    COMMA
    PARAM "is_orig" {
      TYPE-ATOM "bool"
    }
    COMMA
    PARAM "version" {
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "some_dcid" {
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "some_scid" {
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "some_retoken" {
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "some_integ_tag" {
      TYPE-ATOM "string"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      IDENTIFIER "SomeEvtGroup"
    }
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      IDENTIFIER "c"
      SEMI
    }
    RBRACE
  }
}
