FUNC-DECL "event" "SomeModule::some_raised_evt" {
  PARAMS {
    PARAM "c" {
      TYPE-ATOM "connection"
    }
    PARAM "is_orig" {
      TYPE-ATOM "bool"
    }
    PARAM "version" {
      TYPE-ATOM "count"
    }
    PARAM "some_dcid" {
      TYPE-ATOM "string"
    }
    PARAM "some_scid" {
      TYPE-ATOM "string"
    }
    PARAM "some_retoken" {
      TYPE-ATOM "string"
    }
    PARAM "some_integ_tag" {
      TYPE-ATOM "string"
    }
  }
  ATTR-LIST {
    ATTR "&group" {
      IDENTIFIER "SomeEvtGroup"
    }
  }
  BODY {
    PRINT {
      IDENTIFIER "c"
      SEMI
    }
  }
}
