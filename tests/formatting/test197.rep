COMMENT-LEADING "# Balanced fill: last arg should not be orphaned on its own line."
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "check_value"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "foo"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          LOCAL-DECL {
            KEYWORD "local"
            SP
            IDENTIFIER "pt"
            DECL-INIT {
              ASSIGN "="
              CALL {
                IDENTIFIER "Cluster::rr_topic"
                ARGS {
                  LPAREN
                  IDENTIFIER "Cluster::proxy_pool"
                  COMMA
                  CONSTANT "\"application-identification\""
                  RPAREN
                }
              }
            }
            SEMI
          }
          EXPR-STMT {
            CALL {
              IDENTIFIER "Cluster::publish"
              ARGS {
                LPAREN
                IDENTIFIER "pt"
                COMMA
                IDENTIFIER "mark_server"
                COMMA
                CALL {
                  IDENTIFIER "to_addr"
                  ARGS {
                    LPAREN
                    FIELD-ACCESS {
                      IDENTIFIER "uri"
                      DOLLAR
                      IDENTIFIER "netlocation"
                    }
                    RPAREN
                  }
                }
                COMMA
                IDENTIFIER "p"
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
