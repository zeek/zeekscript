FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-WITH-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "test1"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          RBRACE
        }
      }
      ELSE-BODY {
        KEYWORD "else"
        SP
        COMMENT-TRAILING "# aaaa bb bbb cccc"
        BLOCK {
          LBRACE
          EXPR-STMT {
            CALL {
              IDENTIFIER "bar"
              ARGS {
                LPAREN
                RPAREN
              }
            }
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
