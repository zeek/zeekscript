FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    WHEN {
      KEYWORD "when [bar]"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        PRINT {
          KEYWORD "print"
          SP
          IDENTIFIER "bar"
          SEMI
        }
      }
    }
    WHEN {
      KEYWORD "when [bar, baz]"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          PRINT {
            KEYWORD "print"
            SP
            IDENTIFIER "bar"
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
