COMMENT-LEADING "#@ BEGIN"
FUNC-DECL {
  KEYWORD "function"
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "bar"
        ARGS {
          LPAREN
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
COMMENT-LEADING "#@ END"
