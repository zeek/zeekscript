EXPR-STMT {
  BINARY-OP "=" {
    IDENTIFIER "age_d"
    OP "="
    DIV {
      CALL {
        IDENTIFIER "interval_to_double"
        ARGS {
          LPAREN
          BINARY-OP "-" {
            CALL {
              IDENTIFIER "network_time"
              ARGS {
                LPAREN
                RPAREN
              }
            }
            OP "-"
            FIELD-ACCESS {
              IDENTIFIER "cert"
              DOLLAR
              IDENTIFIER "not_valid_before"
            }
          }
          RPAREN
        }
      }
      OP "/"
      CONSTANT "86400.0"
    }
  }
  SEMI
}
