FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "src_host" {
      COLON
      TYPE-ATOM "addr"
    }
    COMMA
    PARAM "services" {
      COLON
      TYPE-ATOM "int"
    }
    COMMA
    PARAM "regions" {
      COLON
      TYPE-ATOM "int"
    }
    COMMA
    PARAM "endpoints" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "NOTICE"
        ARGS {
          LPAREN
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              FIELD-ASSIGN "note" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "Some_Notice_Type"
              }
              COMMA
              FIELD-ASSIGN "msg" {
                DOLLAR
                ASSIGN "="
                CALL {
                  IDENTIFIER "fmt"
                  ARGS {
                    LPAREN
                    CONSTANT "\"Some long format string describing something with multiple parameters (%d items across %d groups within the last %s).\""
                    COMMA
                    IDENTIFIER "services"
                    COMMA
                    IDENTIFIER "regions"
                    COMMA
                    IDENTIFIER "some_window"
                    RPAREN
                  }
                }
              }
              COMMA
              FIELD-ASSIGN "sub" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "endpoints"
              }
              COMMA
              FIELD-ASSIGN "src" {
                DOLLAR
                ASSIGN "="
                IDENTIFIER "src_host"
              }
              COMMA
              FIELD-ASSIGN "identifier" {
                DOLLAR
                ASSIGN "="
                CALL {
                  IDENTIFIER "cat"
                  ARGS {
                    LPAREN
                    IDENTIFIER "src_host"
                    RPAREN
                  }
                }
              }
              RBRACKET
            }
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
