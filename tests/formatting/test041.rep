LOCAL-DECL {
  KEYWORD "local"
  SP
  IDENTIFIER "x"
  DECL-INIT {
    ASSIGN "="
    CALL {
      IDENTIFIER "set"
      ARGS {
        LPAREN
        CONSTANT "\"a\""
        COMMA
        CONSTANT "\"b\""
        COMMA
        CONSTANT "\"c\""
        COMMA
        CONSTANT "\"d\""
        COMMA
        CONSTANT "\"e\""
        RPAREN
      }
    }
  }
  SEMI
}
