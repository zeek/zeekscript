EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "option"
    SP
    IDENTIFIER "some_hosts"
    DECL-INIT {
      ASSIGN "="
      CALL {
        IDENTIFIER "set"
        ARGS {
          LPAREN
          CONSTANT "\"some.host.example.com\""
          COMMA
          CONSTANT "\"another.longer.hostname.example.org\""
          COMMA
          CONSTANT "\"yet.another.host.example.net\""
          RPAREN
        }
      }
    }
    SEMI
  }
  RBRACE
}
