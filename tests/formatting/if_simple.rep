          BINARY-OP "||" {
            BINARY-OP "||" {
              BINARY-OP "<" {
                IDENTIFIER "s0"
                OP "<"
                CONSTANT "0"
              }
              OP "||"
              BINARY-OP ">" {
                IDENTIFIER "s1"
                OP ">"
                CONSTANT "0"
              }
            }
            OP "||"
            BINARY-OP "<" {
              IDENTIFIER "s2"
              OP "<"
              CONSTANT "0"
            }
          }
