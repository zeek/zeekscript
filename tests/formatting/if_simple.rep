            IDENTIFIER "s3"
            OP ">"
            CONSTANT "0"
          }
        }
        OP "||"
        BINARY-OP "<" {
          IDENTIFIER "s4"
          OP "<"
          CONSTANT "0"
        }
      }
      RPAREN
      BODY {
        EXPR-STMT {
          CALL {
            IDENTIFIER "foo"
            ARGS {
              LPAREN
              RPAREN
