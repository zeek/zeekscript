COMMENT-LEADING "# Simple if/else: one-liners, inline if sequences, !in, negated conditions, empty bodies, else with comment."
BLANK
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "&&" {
        HAS-FIELD {
          BINARY-OP "&&" {
            BINARY-OP "&&" {
              IDENTIFIER "some_long_var_aa"
              OP "&&"
              BINARY-OP "==" {
                FIELD-ACCESS {
                  IDENTIFIER "some_var"
                  DOLLAR
                  IDENTIFIER "some_field"
                }
                OP "=="
                CONSTANT "\"ok\""
              }
            }
            OP "&&"
            IDENTIFIER "other"
          }
          OP "?$"
          IDENTIFIER "some_chain"
        }
        OP "&&"
        BINARY-OP ">" {
          CARDINALITY {
            OP "|"
            FIELD-ACCESS {
              IDENTIFIER "other"
              DOLLAR
              IDENTIFIER "some_chain"
            }
            OP "|"
          }
          OP ">"
          CONSTANT "2"
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          RBRACE
        }
      }
    }
    RBRACE
  }
}
BLANK
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      HAS-FIELD {
        BINARY-OP "||" {
          BINARY-OP "||" {
            HAS-FIELD {
              NEGATION {
                OP "!"
                IDENTIFIER "aa"
              }
              OP "?$"
              IDENTIFIER "bb_chain"
            }
            OP "||"
            BINARY-OP "==" {
              CARDINALITY {
                OP "|"
                FIELD-ACCESS {
                  IDENTIFIER "aa"
                  DOLLAR
                  IDENTIFIER "bb_chain"
                }
                OP "|"
              }
              OP "=="
              CONSTANT "0"
            }
          }
          OP "||"
          NEGATION {
            OP "!"
            INDEX {
              FIELD-ACCESS {
                IDENTIFIER "aa"
                DOLLAR
                IDENTIFIER "bb_chain"
              }
              SUBSCRIPTS {
                LBRACKET
                CONSTANT "0"
                RBRACKET
              }
            }
          }
        }
        OP "?$"
        IDENTIFIER "cc"
      }
      RPAREN
      BODY {
        RETURN {
          KEYWORD "return"
          SP
          IDENTIFIER "dd"
          SEMI
        }
      }
    }
    RBRACE
  }
}
BLANK
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "a" {
      COLON
      TYPE-ATOM "int"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "!in" {
        INDEX {
          IDENTIFIER "some_very_long_access_to_a_member"
          SUBSCRIPTS {
            LBRACKET
            IDENTIFIER "foo"
            RBRACKET
          }
        }
        OP "!in"
        FIELD-ACCESS {
          IDENTIFIER "SomeModule::other"
          DOLLAR
          IDENTIFIER "nested_field"
        }
      }
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          PRINT {
            KEYWORD "print"
            SP
            CONSTANT "\"hi\""
            SEMI
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
