GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_state"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      LBRACKET
      TYPE-ATOM "SomeModule::CertInfo"
      COMMA
      TYPE-ATOM "SomeModule::AltNameInfo"
      COMMA
      TYPE-ATOM "SomeModule::ConstraintInfo"
      RBRACKET
      KEYWORD "of"
      SP
      TYPE-ATOM "count"
    }
  }
  ATTR-LIST {
    ATTR "&default" {
      ASSIGN "="
      CONSTANT "0"
    }
  }
  SEMI
}
