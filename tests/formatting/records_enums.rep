REDEF-ENUM "Notice::Type" {
  KEYWORD "redef"
  SP
  KEYWORD "enum"
  SP
  IDENTIFIER "Notice::Type"
  ASSIGN "+="
  LBRACE
  COMMENT-LEADING "## Anomalous behavior detected."
  ENUM-VALUE "Found"
  RBRACE
  SEMI
}
BLANK
EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  TYPEDECL-ENUM "Flag" {
    KEYWORD "type"
    SP
    IDENTIFIER "Flag"
    COLON
    SP
    TYPE-ENUM {
      KEYWORD "enum"
      SP
      LBRACE
      ENUM-VALUE "ControlPkt" "= 0x80"
      COMMA
      COMMENT-TRAILING "#< Control messages between tunnel endpoints."
      ENUM-VALUE "CriticalOpt" "= 0x40"
      COMMA
      TRAILING-COMMA
      COMMENT-TRAILING "#< Geneve header contains a critical option."
      RBRACE
    }
    ATTR-LIST {
      ATTR "&redef"
    }
    SEMI
  }
  RBRACE
}
BLANK
TYPEDECL-RECORD "Foo" {
  KEYWORD "type"
  SP
  IDENTIFIER "Foo"
  COLON
  SP
  TYPE-RECORD {
    KEYWORD "record"
    SP
    LBRACE
    FIELD "x" {
      COLON
      TYPE-ATOM "count"
      SEMI
    }
    FIELD "y" {
      COLON
      TYPE-ATOM "string"
      SEMI
    }
    RBRACE
  }
  ATTR-LIST {
    ATTR "&redef"
  }
  SEMI
}
BLANK
EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  COMMENT-LEADING "## Documentation comment."
  TYPEDECL-ENUM "Foo" {
    KEYWORD "type"
    SP
    IDENTIFIER "Foo"
    COLON
    SP
    TYPE-ENUM {
      KEYWORD "enum"
      SP
      LBRACE
      ENUM-VALUE "AAA"
      COMMA
      COMMENT-TRAILING "##< Trailing comment on AAA"
      ENUM-VALUE "BBB"
      COMMENT-TRAILING "##< Trailing comment on BBB"
      RBRACE
    }
    SEMI
  }
  RBRACE
}
BLANK
EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  REDEF-RECORD "Aaa::Aaaa" {
    KEYWORD "redef"
    SP
    KEYWORD "record"
    SP
    IDENTIFIER "Aaa::Aaaa"
    ASSIGN "+="
    LBRACE
    FIELD "aaaa_aaa" {
      COLON
      TYPE-ATOM "count"
      ATTR-LIST {
        ATTR "&default" {
          ASSIGN "="
          CONSTANT "0"
        }
      }
      SEMI
    }
    BLANK
    COMMENT-LEADING "# aaaaaaa_aaaaa: string &log &optional;"
    RBRACE
    SEMI
  }
  RBRACE
}
BLANK
EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  TYPEDECL-ENUM "foo" {
    KEYWORD "type"
    SP
    IDENTIFIER "foo"
    COLON
    SP
    TYPE-ENUM {
      KEYWORD "enum"
      SP
      LBRACE
      ENUM-VALUE "AAAAA"
      COMMA
      ENUM-VALUE "BBBBB"
      COMMA
      ENUM-VALUE "CCCCC"
      COMMA
      ENUM-VALUE "DDDDD"
      COMMA
      ENUM-VALUE "EEEEE"
      COMMA
      ENUM-VALUE "FFFFF"
      COMMA
      ENUM-VALUE "GGGGG"
      COMMA
      ENUM-VALUE "HHHHH"
      COMMA
      ENUM-VALUE "IIIII"
      COMMA
      ENUM-VALUE "JJJJJ"
      COMMA
      ENUM-VALUE "KKKKK"
      COMMA
      BLANK
      ENUM-VALUE "LLLLL"
      COMMA
      TRAILING-COMMA
      RBRACE
    }
    SEMI
  }
  RBRACE
}
BLANK
EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  COMMENT-LEADING "#@ FORMAT: FILL-ENUM"
  TYPEDECL-ENUM "Foo" {
    KEYWORD "type"
    SP
    IDENTIFIER "Foo"
    COLON
    SP
    TYPE-ENUM {
      KEYWORD "enum"
      SP
      LBRACE
      ENUM-VALUE "AAAA"
      COMMA
      ENUM-VALUE "BBBB"
      COMMA
      ENUM-VALUE "CCCC"
      COMMA
      ENUM-VALUE "DDDD"
      COMMA
      ENUM-VALUE "EEEE"
      COMMA
      ENUM-VALUE "FFFF"
      COMMA
      ENUM-VALUE "GGGG"
      COMMA
      ENUM-VALUE "HHHH"
      COMMA
      ENUM-VALUE "IIII"
      COMMA
      ENUM-VALUE "JJJJ"
      COMMA
      ENUM-VALUE "KKKK"
      COMMA
      ENUM-VALUE "LLLL"
      COMMA
      COMMENT-TRAILING "# trailing"
      ENUM-VALUE "MMMM"
      COMMA
      BLANK
      ENUM-VALUE "NNNN"
      COMMA
      ENUM-VALUE "OOOO"
      COMMA
      TRAILING-COMMA
      RBRACE
    }
    SEMI
  }
  RBRACE
}
