GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "service_patterns"
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      ARGS {
        LPAREN
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "/(.*\\.)?(akamaized|akamaihd|akamai|akamaiapis)\\.(com|net)/i"
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"akamai\""
        }
        COMMA
        COMMENT-LEADING "# Meta domains."
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "/(.*\\.)?(meta|(oculus(cdn)?)|facebook(-dns|-hardware)?|fbcdn)\\.(com|net)/i"
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"facebook\""
        }
        COMMA
        TRAILING-COMMA
        RPAREN
      }
    }
  }
  SEMI
}
