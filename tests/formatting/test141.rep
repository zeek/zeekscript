TYPE-DECL "SomeInfo" {
  TYPE-RECORD {
    FIELD "ts" {
      TYPE-ATOM "time"
      ATTR-LIST {
        ATTR "&log"
      }
    }
    FIELD "uid" {
      TYPE-ATOM "string"
      ATTR-LIST {
        ATTR "&log"
      }
    }
    FIELD "addr_field" {
      TYPE-ATOM "addr"
      ATTR-LIST {
        ATTR "&log"
      }
    }
    COMMENT-LEADING "## A timestamp field."
    COMMENT-LEADING "## A unique identifier."
    COMMENT-LEADING "## A network address."
  }
  SEMI
}
