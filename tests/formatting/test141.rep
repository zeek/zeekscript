TYPE-DECL "SomeInfo" {
  KEYWORD "type"
  IDENTIFIER "SomeInfo"
  COLON
  SP
  TYPE-RECORD {
    KEYWORD "record"
    LBRACE
    COMMENT-LEADING "## A timestamp field."
    FIELD "ts" {
      COLON
      TYPE-ATOM "time"
      ATTR-LIST {
        ATTR "&log"
      }
      SEMI
    }
    BLANK
    COMMENT-LEADING "## A unique identifier."
    FIELD "uid" {
      COLON
      TYPE-ATOM "string"
      ATTR-LIST {
        ATTR "&log"
      }
      SEMI
    }
    BLANK
    COMMENT-LEADING "## A network address."
    FIELD "addr_field" {
      COLON
      TYPE-ATOM "addr"
      ATTR-LIST {
        ATTR "&log"
      }
      SEMI
    }
    RBRACE
  }
  SEMI
}
