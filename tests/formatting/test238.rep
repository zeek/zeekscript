EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "global"
    SP
    IDENTIFIER "has_text_runs"
    DECL-TYPE {
      COLON
      TYPE-FUNC-RET "function" {
        PARAMS {
          LPAREN
          PARAM "data" {
            COLON
            TYPE-ATOM "string"
          }
          COMMA
          PARAM "length" {
            COLON
            TYPE-ATOM "count"
          }
          COMMA
          PARAM "run_min" {
            COLON
            TYPE-ATOM "count"
          }
          COMMA
          PARAM "runs_min" {
            COLON
            TYPE-ATOM "count"
          }
          RPAREN
        }
        COLON
        RETURNS {
          TYPE-ATOM "bool"
        }
      }
    }
    SEMI
  }
  RBRACE
}
