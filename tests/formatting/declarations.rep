      TYPE-ATOM "string"
    }
  }
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      ARGS {
        LPAREN
        BINARY-OP "=" {
          CONSTANT "[1]"
          OP "="
          CONSTANT "\"a\""
        }
        RPAREN
      }
    }
  }
  SEMI
}
