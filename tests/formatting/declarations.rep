COMMENT-LEADING "# Declarations: global, local, const, option with types, attributes, wrapping."
BLANK
GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_table"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "string"
        RBRACKET
      }
      KEYWORD "of"
      SP
      TYPE-ATOM "count"
    }
  }
  ATTR-LIST {
    ATTR "&default" {
      ASSIGN "="
      IDENTIFIER "some_long_default_expression_here"
    }
    ATTR "&redef"
  }
  SEMI
}
BLANK
GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_event_decl"
  DECL-TYPE {
    COLON
    TYPE-FUNC "event" {
      PARAMS {
        LPAREN
        PARAM "o" {
          COLON
          TYPE-ATOM "string"
        }
        COMMA
        PARAM "label" {
          COLON
          TYPE-ATOM "string"
        }
        COMMA
        PARAM "conf" {
          COLON
          TYPE-ATOM "score"
        }
        COMMA
        PARAM "sources" {
          COLON
          TYPE-PARAMETERIZED "set" {
            SUBSCRIPTS {
              LBRACKET
              TYPE-ATOM "string"
              RBRACKET
            }
          }
        }
        COMMA
        PARAM "caller" {
          COLON
          TYPE-ATOM "string"
        }
        RPAREN
      }
    }
  }
  SEMI
}
BLANK
GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "x"
  DECL-INIT {
    ASSIGN "="
    CONSTANT "42"
  }
  SEMI
}
