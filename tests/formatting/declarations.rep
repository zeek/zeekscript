BLANK
GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_long_cache_name"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "set" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "string"
        COMMA
        TYPE-ATOM "subnet"
        COMMA
        TYPE-ATOM "subnet"
        COMMA
        TYPE-ATOM "transport_proto"
        COMMA
        TYPE-ATOM "SomeModule::SomeType"
        RBRACKET
      }
    }
  }
  ATTR-LIST {
    ATTR "&read_expire" {
      ASSIGN "="
      IDENTIFIER "cache_interval"
    }
  }
  SEMI
}
BLANK
GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "some_tracking_var"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "count"
        COMMA
        TYPE-ATOM "string"
        RBRACKET
      }
      KEYWORD "of"
      SP
      TYPE-ATOM "TrackingRec"
    }
  }
  ATTR-LIST {
    ATTR "&default_insert" {
      ASSIGN "="
      CALL {
        IDENTIFIER "TrackingRec"
        ARGS {
          LPAREN
          FIELD-ASSIGN "field" {
            DOLLAR
            ASSIGN "="
            IDENTIFIER "val"
          }
          RPAREN
        }
      }
    }
    ATTR "&create_expire" {
      ASSIGN "="
      INTERVAL "10" "sec"
    }
    ATTR "&redef"
  }
  SEMI
}
BLANK
GLOBAL-DECL {
  KEYWORD "redef"
  SP
  IDENTIFIER "SomeModule::some_generic_packet_thresholds"
  DECL-INIT {
    ASSIGN "+="
