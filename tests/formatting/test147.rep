GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "tbl"
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      ARGS {
        LPAREN
        BINARY-OP "=" {
          CONSTANT "[1]"
          OP "="
          CONSTANT "\"a\""
        }
        COMMA
        BINARY-OP "=" {
          CONSTANT "[2]"
          OP "="
          CONSTANT "\"b\""
        }
        RPAREN
      }
    }
  }
  SEMI
}
