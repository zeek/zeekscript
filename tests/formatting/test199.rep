COMMENT-LEADING "# Comment before else body stays with the else branch."
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-WITH-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      HAS-FIELD {
        IDENTIFIER "c"
        OP "?$"
        IDENTIFIER "vpce_id"
      }
      RPAREN
      BODY {
        EXPR-STMT {
          BINARY-OP "=" {
            IDENTIFIER "vpce_id"
            OP "="
            FIELD-ACCESS {
              IDENTIFIER "c"
              DOLLAR
              IDENTIFIER "vpce_id"
            }
          }
          SEMI
        }
      }
      ELSE-BODY {
        KEYWORD "else"
        SP
        COMMENT-LEADING "# No VPC endpoint found, cannot enrich."
        RETURN {
          KEYWORD "return"
          SP
          CONSTANT "\"\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
