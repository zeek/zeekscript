GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "some_patterns"
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      ARGS {
        LPAREN
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "/aaa/i"
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"aaa\""
        }
        COMMA
        COMMENT-LEADING "# Group end\n"
        BINARY-OP "=" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              CONSTANT "/bbb/i"
              RBRACKET
            }
          }
          OP "="
          CONSTANT "\"bbb\""
        }
        COMMA
        TRAILING-COMMA
        RPAREN
      }
    }
  }
  SEMI
}
SEMI
