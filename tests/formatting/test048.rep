FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    PARAM "c" {
      COLON
      TYPE-ATOM "connection"
    }
    RPAREN
  }
  ATTR-LIST {
    ATTR "&group" {
      ASSIGN "="
      IDENTIFIER "bar"
    }
  }
  BODY {
    LBRACE
    PRINT {
      KEYWORD "print"
      SP
      IDENTIFIER "c"
      SEMI
    }
    RBRACE
  }
}
