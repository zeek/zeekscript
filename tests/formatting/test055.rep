EXPORT {
  KEYWORD "export"
  SP
  LBRACE
  GLOBAL-DECL {
    KEYWORD "global"
    SP
    IDENTIFIER "SomeModule::some_long_handler"
    DECL-TYPE {
      COLON
      TYPE-FUNC "event" {
        PARAMS {
          LPAREN
          PARAM "anomaly_data" {
            COLON
            TYPE-ATOM "SomePredictions"
          }
          RPAREN
        }
      }
    }
    SEMI
  }
  RBRACE
}
