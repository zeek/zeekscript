FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "x"
      RPAREN
      BODY {
        COMMENT-LEADING "# comment before body"
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "\"done\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
