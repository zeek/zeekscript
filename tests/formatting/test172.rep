GLOBAL-DECL {
  KEYWORD "global"
  IDENTIFIER "ftp_connections_cache"
  COLON
  TYPE-PARAMETERIZED "set" {
    LBRACKET
    TYPE-ATOM "string"
    COMMA
    TYPE-ATOM "string"
    COMMA
    TYPE-ATOM "string"
    RBRACKET
  }
  ATTR-LIST {
    ATTR "&read_expire" {
      ASSIGN "="
      IDENTIFIER "cache_interval"
    }
  }
  SEMI
}
