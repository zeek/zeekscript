GLOBAL-DECL {
  KEYWORD "global"
  SP
  IDENTIFIER "coalesced_state"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      SUBSCRIPTS {
        LBRACKET
        TYPE-ATOM "X509::Certificate"
        COMMA
        TYPE-ATOM "X509::SubjectAlternativeName"
        COMMA
        TYPE-ATOM "X509::BasicConstraints"
        RBRACKET
      }
      KEYWORD "of"
      SP
      TYPE-ATOM "count"
    }
  }
  ATTR-LIST {
    ATTR "&create_expire" {
      ASSIGN "="
      IDENTIFIER "coal_ival"
    }
    ATTR "&default" {
      ASSIGN "="
      CONSTANT "0"
    }
  }
  SEMI
}
