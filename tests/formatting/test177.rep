GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "xs"
  DECL-TYPE {
    COLON
    TYPE-OF "vector" {
      KEYWORD "of"
      SP
      TYPE-ATOM "count"
    }
  }
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "vector"
      ARGS {
        LPAREN
        CONSTANT "1"
        COMMA
        CONSTANT "2"
        COMMA
        CONSTANT "3"
        RPAREN
      }
    }
  }
  SEMI
}
