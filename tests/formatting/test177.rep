REDEF-RECORD "SSL::Info" {
  KEYWORD "redef"
  SP
  KEYWORD "record"
  SP
  IDENTIFIER "SSL::Info"
  ASSIGN "+="
  LBRACE
  COMMENT-LEADING "# Flag indicating if \"early data\" extension was sent in Client Hello."
  FIELD "early_data" {
    COLON
    TYPE-ATOM "bool"
    ATTR-LIST {
      ATTR "&default" {
        ASSIGN "="
        CONSTANT "F"
      }
    }
    SEMI
  }
  RBRACE
  SEMI
}
