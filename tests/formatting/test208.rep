FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "register_use_case"
  PARAMS {
    LPAREN
    PARAM "use_case" {
      COLON
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "notice_lambda" {
      COLON
      TYPE-FUNC "function" {
        PARAMS {
          LPAREN
          PARAM "o_h" {
            COLON
            TYPE-ATOM "addr"
          }
          COMMA
          PARAM "si" {
            COLON
            TYPE-ATOM "ProxySourceInfo"
          }
          RPAREN
        }
      }
    }
    COMMA
    PARAM "volume_threshold" {
      COLON
      TYPE-ATOM "double"
      ATTR-LIST {
        ATTR "&default" {
          ASSIGN "="
          IDENTIFIER "default_volume_threshold"
        }
      }
    }
    RPAREN
  }
  BODY {
    LBRACE
    RBRACE
  }
}
