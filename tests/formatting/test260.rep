FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "foo"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      IDENTIFIER "test"
      RPAREN
      BODY {
        BLOCK {
          LBRACE
          WHILE {
            KEYWORD "while"
            SP
            LPAREN
            IDENTIFIER "cond"
            RPAREN
            BODY {
              BLOCK {
                LBRACE
                IF-WITH-ELSE {
                  KEYWORD "if"
                  SP
                  LPAREN
                  IDENTIFIER "cond2"
                  RPAREN
                  BODY {
                    EXPR-STMT {
                      IDENTIFIER "stmt"
                      SEMI
                    }
                  }
                  ELSE-BODY {
                    KEYWORD "else"
                    SP
                    KW-STMT {
                      KEYWORD "break"
                      SEMI
                    }
                  }
                }
                RBRACE
              }
            }
          }
          RBRACE
        }
      }
    }
    RBRACE
  }
}
