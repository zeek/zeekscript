GLOBAL-DECL {
  KEYWORD "const"
  SP
  IDENTIFIER "tbl"
  DECL-TYPE {
    COLON
    TYPE-PARAMETERIZED "table" {
      LBRACKET
      TYPE-ATOM "count"
      RBRACKET
      KEYWORD "of"
      SP
      TYPE-ATOM "string"
    }
  }
  DECL-INIT {
    ASSIGN "="
    CONSTRUCTOR {
      KEYWORD "table"
      LPAREN
      BINARY-OP "=" {
        CONSTANT "[1]"
        OP "="
        CONSTANT "\"a\""
      }
      RPAREN
    }
  }
  SEMI
}
