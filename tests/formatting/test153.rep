GLOBAL-DECL {
  KEYWORD "const"
  IDENTIFIER "tbl"
  COLON
  TYPE-PARAMETERIZED "table" {
    LBRACKET
    TYPE-ATOM "count"
    RBRACKET
    KEYWORD "of"
    TYPE-ATOM "string"
  }
  ASSIGN "="
  CONSTRUCTOR {
    KEYWORD "table"
    LPAREN
    BINARY-OP "=" {
      CONSTANT "[1]"
      OP "="
      CONSTANT "\"a\""
    }
    RPAREN
  }
  SEMI
}
