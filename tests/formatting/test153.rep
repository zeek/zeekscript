FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    ASSERT {
      KEYWORD "assert"
      SP
      BINARY-OP "==" {
        CONSTANT "1"
        OP "=="
        CONSTANT "1"
      }
      SEMI
    }
    COMMENT-TRAILING "# sanity"
    RBRACE
  }
}
