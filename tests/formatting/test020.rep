COMMENT-LEADING "#@ BEGIN-SKIP-TESTING\n"
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "val" {
      COLON
      TYPE-ATOM "string"
    }
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "some_call"
        ARGS {
          LPAREN
          IDENTIFIER "val"
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
COMMENT-LEADING "\n#@ END-SKIP-TESTING"
