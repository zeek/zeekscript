FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    PARAM "si" {
      COLON
      TYPE-ATOM "SomeInfo"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "&&" {
        BINARY-OP "&&" {
          BINARY-OP ">" {
            IDENTIFIER "coal_max_entries"
            OP ">"
            CONSTANT "0"
          }
          OP "&&"
          BINARY-OP ">=" {
            CARDINALITY {
              OP "|"
              IDENTIFIER "coalesced_state"
              OP "|"
            }
            OP ">="
            IDENTIFIER "coal_max_entries"
          }
        }
        OP "&&"
        BINARY-OP "!in" {
          INDEX-LITERAL {
            ARGS {
              LBRACKET
              IDENTIFIER "server_name"
              COMMA
              IDENTIFIER "server_subj"
              COMMA
              IDENTIFIER "server_issuer"
              COMMA
              IDENTIFIER "client_subj"
              COMMA
              IDENTIFIER "client_issuer"
              COMMA
              IDENTIFIER "ja3"
              RBRACKET
            }
          }
          OP "!in"
          IDENTIFIER "coalesced_state"
        }
      }
      RPAREN
      BODY {
        RETURN-VOID {
          KEYWORD "return"
          SP
          SEMI
        }
      }
    }
    RBRACE
  }
}
