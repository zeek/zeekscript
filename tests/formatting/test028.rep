FUNC-DECL {
  KEYWORD "event"
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    EXPR-STMT {
      CALL {
        IDENTIFIER "SomeModule::some_register_fn"
        ARGS {
          LPAREN
          IDENTIFIER "SomeModule::SOME_ANALYZER"
          COMMA
          INDEX-LITERAL {
            LBRACKET
            FIELD-ASSIGN "get_handle" {
              DOLLAR
              ASSIGN "="
              IDENTIFIER "SomeModule::get_handle"
            }
            COMMA
            FIELD-ASSIGN "describe" {
              DOLLAR
              ASSIGN "="
              IDENTIFIER "SomeModule::describe_it"
            }
            RBRACKET
          }
          RPAREN
        }
      }
      SEMI
    }
    RBRACE
  }
}
