BLANK
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "f"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    SWITCH {
      KEYWORD "switch"
      SP
      IDENTIFIER "tag_type"
      LBRACE
      CASE {
        KEYWORD "case"
        SP
        VALUES {
          CONSTANT "\"some_analyzer_udp\""
          COMMA
          CONSTANT "\"some_analyzer_udp_hmac_md5\""
          COMMA
          CONSTANT "\"some_analyzer_udp_hmac_sha1\""
          COMMA
          CONSTANT "\"some_analyzer_udp_hmac_sha256\""
        }
        COLON
        BODY {
          KW-STMT {
            KEYWORD "break"
            SEMI
          }
        }
      }
      RBRACE
    }
    RBRACE
  }
}
