# Switch statements: one-liner expansion, case/default/break, multi-value cases, comments in switch, brace styles, #@ END comments.

function f()
	{
	switch tag_type {
	case "some_analyzer_udp", "some_analyzer_udp_hmac_md5",
	     "some_analyzer_udp_hmac_sha1", "some_analyzer_udp_hmac_sha256":
		break;
	}
	}

function f()
	{
	switch val {
	case 0: break;
	}
	}

function f()
	{
	switch ( val ) {
	case 0: break;
	case 1: break;
	}
	}

function f()
	{
	switch ( val ) {
	case 0: break;
	}
	}

function set_groups()
	{
	switch foo {
	#@ BEGIN-NOT-TESTED
	case 4:
		rec$field_a = val_a;
		rec$field_b = val_b;
		break;
	#@ END-NOT-TESTED
	}
	}

function foo()
	{
	switch ( n ) {
	case 3: break;
	#@ BEGIN-NOT-TESTED
	case 4: break;
	#@ END-NOT-TESTED
	}
	}

event foo()
	{
	switch val {
	case "bar": # trailing comment
		do_something();
	}
	}

# default with break in switch.
event foo()
	{
	switch auth_type {
	default: break;

	case 3: print "yep";
	}
	}

function xxx()
	{
	switch ( x ) {
	case AAAA: return xxx(xxxxxxxxxx | xxxxxxx);

	case BBBBBBB: return xxxxxxx;

	default:
		#@ BEGIN-NOT-TESTED
		xxxxxxxxxxxxxx(xxx("xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
		                   xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx));
		return xxxxxxxxxx;
	#@ END-NOT-TESTED
	}
	}

function foo()
	{
	switch ( aaa[1] ) {
	case "Aaaa::AAA":
		aaa = Aaaa::AAA;
		break;

	case "Aaaa::BBB":
		#@ BEGIN-NOT-TESTED
		aaa = Aaaa::BBB;
		break;
	#@ END-NOT-TESTED
	}
	}

function foo()
	{
	switch aaa {
	case bbb: return;
	case ccc, ddd: print "aaa";
	default: break;
	}
	}
