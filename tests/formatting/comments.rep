COMMENT-LEADING "# Comments: trailing on various statement types, pre-comments, doc-comments, comment-only file, comment after close, #@ annotations, bare block with comment, pattern table with interleaved comments."
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "zeek_init"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    RBRACE
  }
}
COMMENT-LEADING "# Comment on next line."
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    ADD {
      KEYWORD "add"
      SP
      INDEX {
        IDENTIFIER "some_set"
        SUBSCRIPTS {
          LBRACKET
          IDENTIFIER "val"
          RBRACKET
        }
      }
      SEMI
    }
    COMMENT-TRAILING "# track it"
    DELETE {
      KEYWORD "delete"
      SP
      INDEX {
        IDENTIFIER "some_set"
        SUBSCRIPTS {
          LBRACKET
          IDENTIFIER "val"
          RBRACKET
        }
      }
      SEMI
    }
    COMMENT-TRAILING "# remove it"
    RBRACE
  }
}
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    ASSERT {
      KEYWORD "assert"
      SP
      BINARY-OP "==" {
        CONSTANT "1"
        OP "=="
        CONSTANT "1"
      }
      SEMI
    }
    COMMENT-TRAILING "# sanity"
    RBRACE
  }
}
BLANK
FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    PARAM "a" {
      COLON
      TYPE-ATOM "count"
    }
    COMMA
    PARAM "b" {
      COLON
      TYPE-ATOM "string"
    }
    COMMA
    PARAM "rec" {
      COLON
      TYPE-ATOM "SomeRec"
    }
    RPAREN
  }
  BODY {
    LBRACE
    IF-NO-ELSE {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "in" {
        IDENTIFIER "rec"
        OP "in"
        IDENTIFIER "did_check"
      }
      RPAREN
      COMMENT-TRAILING "#@ BEGIN-SKIP-TESTING"
      BODY {
        RETURN-VOID {
          KEYWORD "return"
          SP
          SEMI
        }
      }
    }
    RBRACE
  }
}
BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    LOCAL-DECL {
      KEYWORD "local"
      SP
      IDENTIFIER "x"
      DECL-INIT {
        ASSIGN "="
        CONSTANT "1"
      }
      SEMI
    }
    COMMENT-TRAILING "# init"
    RBRACE
  }
}
BLANK
