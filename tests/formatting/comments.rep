BLANK
FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    COMMENT-TRAILING "# Start tracking."
    PRINT {
      KEYWORD "print"
      SP
      CONSTANT "1"
      SEMI
    }
    RBRACE
  }
}
BLANK
FUNC-DECL-RET {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  COLON
  RETURNS {
    TYPE-ATOM "count"
  }
  BODY {
    LBRACE
    RETURN {
      KEYWORD "return"
      SP
      CONSTANT "42"
      SEMI
    }
    COMMENT-TRAILING "# the answer"
    RBRACE
  }
}
