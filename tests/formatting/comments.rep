      KEYWORD "set"
      ARGS {
        LPAREN
        CONSTANT "\"timed out\""
        COMMA
        CONSTANT "\"Timeout\""
        COMMA
        CONSTANT "\"Timed out\""
        COMMA
        COMMENT-TRAILING "# Comment 1"
        CONSTANT "\"Error reading command input\""
        COMMA
        COMMENT-TRAILING "# Comment 2"
        TRAILING-COMMA
        RPAREN
      }
    }
  }
  SEMI
}
