FUNC-DECL {
  KEYWORD "event"
  SP
  IDENTIFIER "some_evt"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    ADD {
      KEYWORD "add"
      SP
      INDEX {
        IDENTIFIER "some_set"
        SUBSCRIPTS {
          LBRACKET
          IDENTIFIER "val"
          RBRACKET
        }
      }
      SEMI
    }
    COMMENT-TRAILING "# track it"
    DELETE {
      KEYWORD "delete"
      SP
      INDEX {
        IDENTIFIER "some_set"
        SUBSCRIPTS {
          LBRACKET
          IDENTIFIER "val"
          RBRACKET
        }
      }
      SEMI
    }
    COMMENT-TRAILING "# remove it"
    RBRACE
  }
}
