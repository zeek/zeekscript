FUNC-DECL {
  KEYWORD "function"
  SP
  IDENTIFIER "some_func"
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      SP
      LPAREN
      BINARY-OP "!in" {
        IDENTIFIER "x"
        OP "!in"
        IDENTIFIER "y"
      }
      RPAREN
      BODY {
        PRINT {
          KEYWORD "print"
          SP
          CONSTANT "\"hi\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
