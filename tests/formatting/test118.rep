FUNC-DECL "function" "some_func" {
  PARAMS {
    LPAREN
    RPAREN
  }
  BODY {
    LBRACE
    IF {
      KEYWORD "if"
      LPAREN
      BINARY-OP "!in" {
        IDENTIFIER "x"
        OP "!in"
        IDENTIFIER "y"
      }
      RPAREN
      BODY {
        PRINT {
          KEYWORD "print"
          CONSTANT "\"hi\""
          SEMI
        }
      }
    }
    RBRACE
  }
}
